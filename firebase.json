{
  "apphosting": [
    {
      "backendId": "studio",
      "rootDir": ".",
      "ignore": [
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions",
        "node_modules",
        ".next",
        ".next_old_*",
        ".playwright-cli_old_*",
        "output_old_*"
      ],
      "alwaysDeployFromSource": true
    }
  ],
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true
    },
    "single_project_mode": true
  }
}
