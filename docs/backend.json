
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "사용자의 기본 프로필 정보",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "schoolName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "createdAt"]
    },
    "Center": {
      "title": "Center",
      "type": "object",
      "description": "학습 센터 정보 및 재무 설정",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "financeSettings": {
          "type": "object",
          "properties": {
            "fixedCosts": { "type": "number", "description": "월 고정비 총액" },
            "refundPolicy": {
              "type": "object",
              "properties": {
                "penaltyType": { "type": "string", "enum": ["none", "rate", "fixed"] },
                "penaltyRate": { "type": "number" },
                "penaltyFixed": { "type": "number" }
              }
            },
            "discountPolicy": {
              "type": "object",
              "properties": {
                "order": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "Pricing": {
      "title": "Pricing",
      "type": "object",
      "description": "시즌/학생타입별 28일 기준 기본가",
      "properties": {
        "productId": { "type": "string" },
        "season": { "type": "string", "enum": ["semester", "vacation"] },
        "studentType": { "type": "string", "enum": ["student", "n_student"] },
        "basePrice": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "description": "결제 영수증 스냅샷",
      "properties": {
        "studentId": { "type": "string" },
        "cycleStartDate": { "type": "string", "format": "date" },
        "cycleEndDate": { "type": "string", "format": "date" },
        "basePriceSnapshot": { "type": "number" },
        "discountsSnapshot": { "type": "array" },
        "finalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["issued", "paid", "refunded", "void"] },
        "paidAt": { "type": "string", "format": "date-time" }
      }
    },
    "Refund": {
      "title": "Refund",
      "type": "object",
      "description": "환불 처리 기록",
      "properties": {
        "invoiceId": { "type": "string" },
        "usedDays": { "type": "number" },
        "penalty": { "type": "number" },
        "refundAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["requested", "approved", "paid"] }
      }
    },
    "KpiDaily": {
      "title": "KpiDaily",
      "type": "object",
      "description": "일별 재무 지표 집계",
      "properties": {
        "totalRevenue": { "type": "number" },
        "totalDiscount": { "type": "number" },
        "totalRefund": { "type": "number" },
        "activeStudentCount": { "type": "number" },
        "breakevenStudents": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/centers/{centerId}/pricing/{pricingId}": {
      "schema": { "$ref": "#/entities/Pricing" },
      "description": "가격 매트릭스"
    },
    "/centers/{centerId}/invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/Invoice" },
      "description": "결제 내역"
    },
    "/centers/{centerId}/refunds/{refundId}": {
      "schema": { "$ref": "#/entities/Refund" },
      "description": "환불 내역"
    },
    "/centers/{centerId}/kpiDaily/{date}": {
      "schema": { "$ref": "#/entities/KpiDaily" },
      "description": "일별 KPI 통계"
    }
  }
}
