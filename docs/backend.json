
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "사용자의 기본 프로필 정보",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "schoolName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "createdAt"]
    },
    "Center": {
      "title": "Center",
      "type": "object",
      "description": "학습 센터 정보",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subscriptionTier": { "type": "string" }
      }
    },
    "CenterMember": {
      "title": "CenterMember",
      "type": "object",
      "description": "센터 소속 멤버 역할 및 상태",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "parent", "centerAdmin"] },
        "status": { "type": "string", "enum": ["active", "onHold", "withdrawn"] },
        "displayName": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "linkedStudentIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "StudentProfile": {
      "title": "StudentProfile",
      "type": "object",
      "description": "학생 상세 교육 정보",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "schoolName": { "type": "string" },
        "seatNo": { "type": "number" },
        "targetDailyMinutes": { "type": "number" },
        "parentLinkCode": { "type": "string", "description": "부모님 연동용 4자리 코드" }
      }
    },
    "StudyPlanItem": {
      "title": "StudyPlanItem",
      "type": "object",
      "description": "일일 학습 계획 항목",
      "properties": {
        "title": { "type": "string" },
        "done": { "type": "boolean" },
        "dateKey": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "StudyLogDay": {
      "title": "StudyLogDay",
      "type": "object",
      "description": "일일 누적 학습 시간",
      "properties": {
        "totalMinutes": { "type": "number" },
        "dateKey": { "type": "string" }
      }
    },
    "GrowthProgress": {
      "title": "GrowthProgress",
      "type": "object",
      "description": "학생 성장 레벨 및 스탯",
      "properties": {
        "level": { "type": "number" },
        "currentXp": { "type": "number" },
        "stats": { "type": "object" }
      }
    },
    "DailyReport": {
      "title": "DailyReport",
      "type": "object",
      "description": "학부모 발송 리포트",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "sent"] },
        "dateKey": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "DailyStudentStat": {
      "title": "DailyStudentStat",
      "type": "object",
      "description": "학생별 일일 성과 통계",
      "properties": {
        "todayPlanCompletionRate": { "type": "number" },
        "totalStudyMinutes": { "type": "number" },
        "attendanceStreakDays": { "type": "number" },
        "weeklyPlanCompletionRate": { "type": "number" },
        "studyTimeGrowthRate": { "type": "number" },
        "riskDetected": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "전역 사용자 프로필"
    },
    "/userCenters/{userId}/centers/{centerId}": {
      "schema": { "$ref": "#/entities/CenterMember" },
      "description": "사용자별 가입 센터 정보"
    },
    "/centers/{centerId}": {
      "schema": { "$ref": "#/entities/Center" },
      "description": "센터 기본 데이터"
    },
    "/centers/{centerId}/members/{memberId}": {
      "schema": { "$ref": "#/entities/CenterMember" },
      "description": "센터 내 역할 및 상태 관리"
    },
    "/centers/{centerId}/students/{studentId}": {
      "schema": { "$ref": "#/entities/StudentProfile" },
      "description": "학생 상세 관리 프로필"
    },
    "/centers/{centerId}/plans/{studentId}/weeks/{weekId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/StudyPlanItem" },
      "description": "학생별 학습 계획"
    },
    "/centers/{centerId}/studyLogs/{studentId}/days/{dateKey}": {
      "schema": { "$ref": "#/entities/StudyLogDay" },
      "description": "학생별 일일 학습 시간 로그"
    },
    "/centers/{centerId}/growthProgress/{studentId}": {
      "schema": { "$ref": "#/entities/GrowthProgress" },
      "description": "학생 성장 시스템 데이터"
    },
    "/centers/{centerId}/dailyReports/{reportId}": {
      "schema": { "$ref": "#/entities/DailyReport" },
      "description": "일일 학습 리포트 기록"
    },
    "/centers/{centerId}/dailyStudentStats/{date}/students/{studentId}": {
      "schema": { "$ref": "#/entities/DailyStudentStat" },
      "description": "학생별 일일 성과 지표 통계"
    },
    "/centers/{centerId}/attendanceCurrent/{seatId}": {
      "schema": { "type": "object" },
      "description": "실시간 좌석 및 출결 상태"
    },
    "/centers/{centerId}/counselingReservations/{resId}": {
      "schema": { "type": "object" },
      "description": "상담 예약 데이터"
    },
    "/centers/{centerId}/counselingLogs/{logId}": {
      "schema": { "type": "object" },
      "description": "상담 일지 기록"
    }
  }
}
