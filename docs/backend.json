
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "사용자의 핵심 프로필 정보",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "createdAt"]
    },
    "Center": {
      "title": "Center",
      "type": "object",
      "description": "공부트랙 센터 정보",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subscriptionTier": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "subscriptionTier", "createdAt"]
    },
    "CenterMember": {
      "title": "CenterMember",
      "type": "object",
      "description": "센터 내 사용자 역할 및 멤버십",
      "properties": {
        "role": { "type": "string", "enum": ["admin", "teacher", "student", "parent"] },
        "status": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "status", "joinedAt"]
    },
    "InviteCode": {
      "title": "InviteCode",
      "type": "object",
      "description": "가입용 초대 코드",
      "properties": {
        "centerId": { "type": "string" },
        "intendedRole": { "type": "string" },
        "maxUses": { "type": "number" },
        "usedCount": { "type": "number" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["centerId", "intendedRole", "maxUses", "usedCount"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "사용자 프로필"
        }
      },
      {
        "path": "/centers/{centerId}",
        "definition": {
          "entityName": "Center",
          "schema": { "$ref": "#/backend/entities/Center" },
          "description": "센터 정보"
        }
      },
      {
        "path": "/centers/{centerId}/members/{userId}",
        "definition": {
          "entityName": "CenterMember",
          "schema": { "$ref": "#/backend/entities/CenterMember" },
          "description": "센터 멤버십"
        }
      },
      {
        "path": "/inviteCodes/{code}",
        "definition": {
          "entityName": "InviteCode",
          "schema": { "$ref": "#/backend/entities/InviteCode" },
          "description": "글로벌 초대 코드"
        }
      },
      {
        "path": "/userCenters/{userId}/centers/{centerId}",
        "definition": {
          "entityName": "CenterMember",
          "schema": { "$ref": "#/backend/entities/CenterMember" },
          "description": "사용자별 가입 센터 역인덱스"
        }
      }
    ]
  }
}
