{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "사용자의 핵심 프로필 정보",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "createdAt"]
    },
    "Center": {
      "title": "Center",
      "type": "object",
      "description": "공부트랙 센터 정보",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subscriptionTier": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "subscriptionTier", "createdAt"]
    },
    "CenterMember": {
      "title": "CenterMember",
      "type": "object",
      "description": "센터 내 사용자 역할 및 멤버십",
      "properties": {
        "role": { "type": "string", "enum": ["centerAdmin", "teacher", "student", "parent"] },
        "status": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "displayName": { "type": "string" },
        "linkedStudentIds": { "type": "array", "items": { "type": "string" }, "description": "학부모 계정에 연결된 학생 UID 목록" }
      },
      "required": ["role", "status", "joinedAt"]
    },
    "StudyPlanItem": {
      "title": "StudyPlanItem",
      "type": "object",
      "description": "일일 학습 계획 항목",
      "properties": {
        "title": { "type": "string" },
        "done": { "type": "boolean" },
        "weight": { "type": "number" },
        "dateKey": { "type": "string", "description": "YYYY-MM-DD" },
        "category": { "type": "string", "enum": ["study", "personal", "schedule"] },
        "studentId": { "type": "string" }
      }
    },
    "DailyStudentStat": {
      "title": "DailyStudentStat",
      "type": "object",
      "description": "일일 성과 통계",
      "properties": {
        "todayPlanCompletionRate": { "type": "number" },
        "totalStudyMinutes": { "type": "number" },
        "attendanceStreakDays": { "type": "number" },
        "weeklyPlanCompletionRate": { "type": "number" },
        "studyTimeGrowthRate": { "type": "number" },
        "riskDetected": { "type": "boolean" }
      }
    },
    "StudyLogDay": {
      "title": "StudyLogDay",
      "type": "object",
      "description": "일일 학습 시간 기록",
      "properties": {
        "totalMinutes": { "type": "number" },
        "dateKey": { "type": "string" },
        "studentId": { "type": "string" }
      }
    },
    "GrowthProgress": {
      "title": "GrowthProgress",
      "type": "object",
      "description": "성장 트리 진행 상태",
      "properties": {
        "level": { "type": "number" },
        "currentXp": { "type": "number" },
        "nextLevelXp": { "type": "number" },
        "stats": { "type": "object" },
        "skills": { "type": "object" }
      }
    },
    "InviteCode": {
      "title": "InviteCode",
      "type": "object",
      "description": "가입용 초대 코드",
      "properties": {
        "centerId": { "type": "string" },
        "intendedRole": { "type": "string" },
        "maxUses": { "type": "number" },
        "usedCount": { "type": "number" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["centerId", "intendedRole", "maxUses", "usedCount"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "사용자 프로필"
        }
      },
      {
        "path": "/centers/{centerId}",
        "definition": {
          "entityName": "Center",
          "schema": { "$ref": "#/backend/entities/Center" },
          "description": "센터 정보"
        }
      },
      {
        "path": "/centers/{centerId}/members/{userId}",
        "definition": {
          "entityName": "CenterMember",
          "schema": { "$ref": "#/backend/entities/CenterMember" },
          "description": "센터 멤버십"
        }
      },
      {
        "path": "/centers/{centerId}/plans/{studentId}/weeks/{week}/items/{itemId}",
        "definition": {
          "entityName": "StudyPlanItem",
          "schema": { "$ref": "#/backend/entities/StudyPlanItem" },
          "description": "학습 계획 항목"
        }
      },
      {
        "path": "/centers/{centerId}/dailyStudentStats/{date}/students/{studentId}",
        "definition": {
          "entityName": "DailyStudentStat",
          "schema": { "$ref": "#/backend/entities/DailyStudentStat" },
          "description": "일일 통계 데이터"
        }
      },
      {
        "path": "/centers/{centerId}/studyLogs/{userId}/days/{date}",
        "definition": {
          "entityName": "StudyLogDay",
          "schema": { "$ref": "#/backend/entities/StudyLogDay" },
          "description": "일일 학습 시간 로그"
        }
      },
      {
        "path": "/centers/{centerId}/growthProgress/{userId}",
        "definition": {
          "entityName": "GrowthProgress",
          "schema": { "$ref": "#/backend/entities/GrowthProgress" },
          "description": "성장 트리 진행 상태"
        }
      },
      {
        "path": "/inviteCodes/{code}",
        "definition": {
          "entityName": "InviteCode",
          "schema": { "$ref": "#/backend/entities/InviteCode" },
          "description": "글로벌 초대 코드"
        }
      },
      {
        "path": "/userCenters/{userId}/centers/{centerId}",
        "definition": {
          "entityName": "CenterMember",
          "schema": { "$ref": "#/backend/entities/CenterMember" },
          "description": "사용자별 가입 센터 역인덱스"
        }
      }
    ]
  }
}