
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "사용자의 핵심 프로필 정보",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "createdAt"]
    },
    "Center": {
      "title": "Center",
      "type": "object",
      "description": "공부트랙 센터 정보",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subscriptionTier": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "subscriptionTier", "createdAt"]
    },
    "CenterMember": {
      "title": "CenterMember",
      "type": "object",
      "description": "센터 내 사용자 역할 및 멤버십",
      "properties": {
        "role": { "type": "string", "enum": ["centerAdmin", "teacher", "student", "parent"] },
        "status": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "displayName": { "type": "string" },
        "linkedStudentIds": { "type": "array", "items": { "type": "string" }, "description": "학부모 계정에 연결된 학생 UID 목록" }
      },
      "required": ["role", "status", "joinedAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "상담 예약 정보",
      "properties": {
        "centerId": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "startAt": { "type": "string", "format": "date-time" },
        "endAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["requested", "confirmed", "cancelled", "completed", "no_show"] },
        "createdByRole": { "type": "string" },
        "teacherNote": { "type": "string" }
      }
    },
    "CounselingNote": {
      "title": "CounselingNote",
      "type": "object",
      "description": "상담 완료 후 작성되는 상세 일지",
      "properties": {
        "centerId": { "type": "string" },
        "appointmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "content": { "type": "string" },
        "visibility": { "type": "string", "enum": ["student_and_parent", "teacher_only"] }
      }
    },
    "StudyPlanItem": {
      "title": "StudyPlanItem",
      "type": "object",
      "description": "학생의 학습 계획 항목 (To-do)",
      "properties": {
        "title": { "type": "string" },
        "done": { "type": "boolean" },
        "weight": { "type": "number" },
        "dateKey": { "type": "string" },
        "category": { "type": "string", "enum": ["schedule", "personal", "study"] },
        "studentId": { "type": "string" },
        "centerId": { "type": "string" }
      }
    },
    "StudyLogDay": {
      "title": "StudyLogDay",
      "type": "object",
      "description": "일별 누적 학습 시간 로그",
      "properties": {
        "studentId": { "type": "string" },
        "centerId": { "type": "string" },
        "dateKey": { "type": "string" },
        "totalMinutes": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "DailyStudentStat": {
      "title": "DailyStudentStat",
      "type": "object",
      "description": "일일 성과 통계",
      "properties": {
        "studentId": { "type": "string" },
        "centerId": { "type": "string" },
        "todayPlanCompletionRate": { "type": "number" },
        "totalStudyMinutes": { "type": "number" },
        "attendanceStreakDays": { "type": "number" },
        "weeklyPlanCompletionRate": { "type": "number" },
        "studyTimeGrowthRate": { "type": "number" },
        "riskDetected": { "type": "boolean" }
      }
    },
    "GrowthProgress": {
      "title": "GrowthProgress",
      "type": "object",
      "description": "학생의 성장 트리 진행 상태",
      "properties": {
        "level": { "type": "number" },
        "currentXp": { "type": "number" },
        "stats": { "type": "object" },
        "skills": { "type": "object" }
      }
    },
    "AIOutput": {
      "title": "AIOutput",
      "type": "object",
      "description": "AI가 생성한 기록 (위험 감지 등)",
      "properties": {
        "centerId": { "type": "string" },
        "studentId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "사용자 프로필" }
      },
      {
        "path": "/centers/{centerId}/members/{memberId}",
        "definition": { "entityName": "CenterMember", "description": "센터 멤버 정보" }
      },
      {
        "path": "/centers/{centerId}/appointments/{appointmentId}",
        "definition": { "entityName": "Appointment", "description": "상담 예약" }
      },
      {
        "path": "/centers/{centerId}/counselingNotes/{noteId}",
        "definition": { "entityName": "CounselingNote", "description": "상담일지" }
      },
      {
        "path": "/centers/{centerId}/plans/{studentId}/weeks/{weekId}/items/{itemId}",
        "definition": { "entityName": "StudyPlanItem", "description": "주간/일간 학습 계획 상세 항목" }
      },
      {
        "path": "/centers/{centerId}/dailyStudentStats/{date}/students/{studentId}",
        "definition": { "entityName": "DailyStudentStat", "description": "일일 학생 통계" }
      },
      {
        "path": "/centers/{centerId}/studyLogs/{studentId}/days/{date}",
        "definition": { "entityName": "StudyLogDay", "description": "일별 학습 로그" }
      },
      {
        "path": "/centers/{centerId}/growthProgress/{userId}",
        "definition": { "entityName": "GrowthProgress", "description": "성장 진행도" }
      },
      {
        "path": "/centers/{centerId}/records/{recordId}",
        "definition": { "entityName": "AIOutput", "description": "AI 기록 (위험 알림 등)" }
      }
    ]
  }
}
