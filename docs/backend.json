{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "사용자의 핵심 프로필 정보",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "schoolName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "createdAt"]
    },
    "Center": {
      "title": "Center",
      "type": "object",
      "description": "공부트랙 센터 정보",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subscriptionTier": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "subscriptionTier", "createdAt"]
    },
    "CenterMember": {
      "title": "CenterMember",
      "type": "object",
      "description": "센터 내 사용자 역할 및 멤버십",
      "properties": {
        "role": { "type": "string", "enum": ["centerAdmin", "teacher", "student"] },
        "status": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "displayName": { "type": "string" }
      },
      "required": ["role", "status", "joinedAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "상담 예약 정보",
      "properties": {
        "centerId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["requested", "confirmed", "cancelled", "done"] },
        "teacherNote": { "type": "string" }
      }
    },
    "DailyStudentStat": {
      "title": "DailyStudentStat",
      "type": "object",
      "description": "학생의 일일 성과 지표",
      "properties": {
        "centerId": { "type": "string" },
        "studentId": { "type": "string" },
        "dateKey": { "type": "string" },
        "weeklyPlanCompletionRate": { "type": "number" },
        "attendanceStreakDays": { "type": "number" },
        "studyTimeGrowthRate": { "type": "number" },
        "riskDetected": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "사용자 프로필" }
      },
      {
        "path": "/centers/{centerId}/members/{memberId}",
        "definition": { "entityName": "CenterMember", "description": "센터 멤버 정보" }
      },
      {
        "path": "/centers/{centerId}/counselingReservations/{resId}",
        "definition": { "entityName": "Appointment", "description": "상담 예약" }
      },
      {
        "path": "/centers/{centerId}/dailyStudentStats/{dateKey}/students/{studentId}",
        "definition": { "entityName": "DailyStudentStat", "description": "일일 학생 통계" }
      },
      {
        "path": "/centers/{centerId}/plans/{studentId}/weeks/{weekId}/items/{itemId}",
        "definition": { "entityName": "StudyPlanItem", "description": "학습 계획 상세 항목" }
      }
    ]
  }
}