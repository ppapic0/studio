
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "사용자의 기본 프로필 정보",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "schoolName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "createdAt"]
    },
    "Center": {
      "title": "Center",
      "type": "object",
      "description": "학습 센터 정보",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subscriptionTier": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "CenterMember": {
      "title": "CenterMember",
      "type": "object",
      "description": "센터 소속 멤버 및 역할",
      "properties": {
        "id": { "type": "string" },
        "centerId": { "type": "string" },
        "role": { "type": "string", "enum": ["centerAdmin", "teacher", "student"] },
        "status": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "displayName": { "type": "string" }
      },
      "required": ["role", "status"]
    },
    "StudentProfile": {
      "title": "StudentProfile",
      "type": "object",
      "description": "학생별 상세 교육 프로필",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "schoolName": { "type": "string" },
        "seatNo": { "type": "number" },
        "targetDailyMinutes": { "type": "number" }
      }
    },
    "StudyLogDay": {
      "title": "StudyLogDay",
      "type": "object",
      "description": "일일 학습 시간 기록",
      "properties": {
        "totalMinutes": { "type": "number" },
        "dateKey": { "type": "string" },
        "studentId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "전역 사용자 프로필"
    },
    "/centers/{centerId}": {
      "schema": { "$ref": "#/entities/Center" },
      "description": "센터 마스터 데이터"
    },
    "/centers/{centerId}/members/{memberId}": {
      "schema": { "$ref": "#/entities/CenterMember" },
      "description": "센터별 멤버십 정보"
    },
    "/centers/{centerId}/students/{studentId}": {
      "schema": { "$ref": "#/entities/StudentProfile" },
      "description": "학생 상세 관리 데이터"
    },
    "/userCenters/{userId}/centers/{centerId}": {
      "schema": { "$ref": "#/entities/CenterMember" },
      "description": "사용자별 소속 센터 역인덱스 (역할 확인용)"
    },
    "/centers/{centerId}/studyLogs/{studentId}/days/{dateKey}": {
      "schema": { "$ref": "#/entities/StudyLogDay" },
      "description": "학생별 학습 시간 로그"
    }
  }
}
