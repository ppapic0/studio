rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function memberPath(centerId, uid) {
      return /databases/$(database)/documents/centers/$(centerId)/members/$(uid);
    }

    function getRole(centerId, uid) {
      return exists(memberPath(centerId, uid))
        ? get(memberPath(centerId, uid)).data.role
        : null;
    }

    function hasRole(centerId, roles) {
      return isSignedIn() && getRole(centerId, request.auth.uid) in roles;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /centers/{centerId} {
      allow read: if isSignedIn();

      match /members/{memberId} {
        allow read: if isSignedIn() && (
          request.auth.uid == memberId ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        allow write: if hasRole(centerId, ['centerAdmin']);
      }

      // -----------------------------
      // Appointments
      // -----------------------------
      match /appointments/{appointmentId} {
        // 단건 조회
        allow get: if isSignedIn() && (
          resource.data.studentId == request.auth.uid ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );

        // ✅ 목록 조회: 학생도 읽기 허용(동작 우선)
        // (운영상 클라에서 where(studentId==uid)로 제한)
        allow list: if isSignedIn() && (
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          getRole(centerId, request.auth.uid) == 'student'
        );

        // 생성
        allow create: if isSignedIn() && (
          request.resource.data.studentId == request.auth.uid ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );

        // 수정
        allow update: if isSignedIn() && (
          (resource.data.studentId == request.auth.uid &&
           request.resource.data.status == 'cancelled') ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );

        allow delete: if hasRole(centerId, ['centerAdmin', 'teacher']);
      }

      // -----------------------------
      // Counseling Notes
      // -----------------------------
      match /counselingNotes/{noteId} {
        // 단건 조회
        allow get: if isSignedIn() && (
          (resource.data.studentId == request.auth.uid &&
           resource.data.visibility == 'student_and_parent') ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );

        // ✅ 목록 조회: 학생도 읽기 허용(동작 우선)
        // 단, 학생은 visibility가 공개된 것만 의미 있으니
        // 실제 필터는 프론트 where로 처리
        allow list: if isSignedIn() && (
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          getRole(centerId, request.auth.uid) == 'student'
        );

        // 작성/수정/삭제는 스태프만
        allow create, update, delete: if hasRole(centerId, ['centerAdmin', 'teacher']);
      }

      // -----------------------------
      // Plans / Logs / Stats
      // -----------------------------
      match /plans/{studentId}/weeks/{weekId}/items/{itemId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /dailyStudentStats/{date}/students/{studentId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
      }

      match /studyLogs/{studentId}/days/{date} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /growthProgress/{userId} {
        allow read: if isSignedIn() && (
          userId == request.auth.uid ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        allow write: if isSignedIn() && userId == request.auth.uid;
      }

      match /attendanceRecords/{date}/students/{studentId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        allow write: if hasRole(centerId, ['centerAdmin', 'teacher']);
      }
    }

    match /inviteCodes/{code} {
      allow get: if isSignedIn();
    }

    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }
  }
}