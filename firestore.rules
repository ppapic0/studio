rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getMemberData(centerId, uid) {
      return get(/databases/$(database)/documents/centers/$(centerId)/members/$(uid)).data;
    }

    // --- 컬렉션 규칙 ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /centers/{centerId} {
      allow read: if isSignedIn();

      match /members/{memberId} {
        allow read: if isSignedIn() && (
          request.auth.uid == memberId || 
          getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher']
        );
      }

      // 상담 예약 (Appointments)
      match /appointments/{appointmentId} {
        allow get: if isSignedIn() && (
          resource.data.studentId == request.auth.uid ||
          getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher']
        );
        
        // 학생: 본인 예약만 목록 조회 (where studentId == uid 필터 필수)
        allow list: if isSignedIn() && resource.data.studentId == request.auth.uid;
        
        // 스태프: 센터 전체 예약 목록 조회
        allow list: if isSignedIn() && getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher'];
        
        allow create: if isSignedIn() && (
          request.resource.data.studentId == request.auth.uid ||
          getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher']
        );
        
        allow update: if isSignedIn() && (
          (resource.data.studentId == request.auth.uid && request.resource.data.status == 'cancelled') ||
          getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher']
        );
      }

      // 상담일지 (Counseling Notes) - 학생 본인(공개됨) 및 스태프만
      match /counselingNotes/{noteId} {
        allow get: if isSignedIn() && (
          (resource.data.studentId == request.auth.uid && resource.data.visibility == 'student_and_parent') ||
          getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher']
        );

        // 학생: 본인에게 공개된 일지만 목록 조회 (where studentId == uid && visibility == 'student_and_parent' 필터 필수)
        allow list: if isSignedIn() && 
                    resource.data.studentId == request.auth.uid && 
                    resource.data.visibility == 'student_and_parent';

        // 스태프: 센터 전체 일지 목록 조회
        allow list: if isSignedIn() && getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher'];

        allow write: if isSignedIn() && getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher'];
      }

      // 학습 계획 및 기록들
      match /plans/{studentId}/weeks/{weekId}/items/{itemId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId || 
          getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher']
        );
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /dailyStudentStats/{date}/students/{studentId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId || 
          getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher']
        );
      }

      match /studyLogs/{studentId}/days/{date} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId || 
          getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher']
        );
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /growthProgress/{userId} {
        allow read: if isSignedIn() && (
          userId == request.auth.uid ||
          getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher']
        );
        allow write: if isSignedIn() && userId == request.auth.uid;
      }
      
      match /attendanceRecords/{date}/students/{studentId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId ||
          getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher']
        );
        allow write: if isSignedIn() && getMemberData(centerId, request.auth.uid).role in ['centerAdmin', 'teacher'];
      }
    }

    match /inviteCodes/{code} {
      allow get: if isSignedIn();
    }

    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }
  }
}