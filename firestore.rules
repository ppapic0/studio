
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function memberPath(centerId, uid) {
      return /databases/$(database)/documents/centers/$(centerId)/members/$(uid);
    }

    // 멤버 문서에서 역할 가져오기 (실시간 검증)
    function getRole(centerId, uid) {
      let memberDoc = get(memberPath(centerId, uid));
      return memberDoc != null ? memberDoc.data.role : null;
    }

    function hasRole(centerId, roles) {
      return isSignedIn() && getRole(centerId, request.auth.uid) in roles;
    }

    // --- 컬렉션 규칙 ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /centers/{centerId} {
      allow read: if isSignedIn();

      match /members/{memberId} {
        allow read: if isSignedIn() && (
          request.auth.uid == memberId ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        allow write: if hasRole(centerId, ['centerAdmin']);
      }

      // 상담 예약 (Appointments)
      match /appointments/{appointmentId} {
        // 읽기: 본인 데이터거나 스태프인 경우
        allow read: if isSignedIn() && (
          (resource == null || resource.data.studentId == request.auth.uid) ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );

        allow create: if isSignedIn() && (
          request.resource.data.studentId == request.auth.uid ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );

        allow update: if isSignedIn() && (
          (resource.data.studentId == request.auth.uid &&
           request.resource.data.status == 'cancelled') ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );

        allow delete: if hasRole(centerId, ['centerAdmin', 'teacher']);
      }

      // 상담일지 (Counseling Notes)
      match /counselingNotes/{noteId} {
        // 읽기: 공개된 본인 일지거나 스태프인 경우
        allow read: if isSignedIn() && (
          (resource == null || (resource.data.studentId == request.auth.uid && resource.data.visibility == 'student_and_parent')) ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );

        allow create, update, delete: if hasRole(centerId, ['centerAdmin', 'teacher']);
      }

      // 학습 계획 및 기록들
      match /plans/{studentId}/weeks/{weekId}/items/{itemId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /dailyStudentStats/{date}/students/{studentId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
      }

      match /studyLogs/{studentId}/days/{date} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /growthProgress/{userId} {
        allow read: if isSignedIn() && (
          userId == request.auth.uid ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        allow write: if isSignedIn() && userId == request.auth.uid;
      }

      match /attendanceRecords/{date}/students/{studentId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        allow write: if hasRole(centerId, ['centerAdmin', 'teacher']);
      }
    }

    match /inviteCodes/{code} {
      allow get: if isSignedIn();
    }

    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
