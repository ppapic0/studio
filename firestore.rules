
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(centerId, roles) {
      let memberPath = /databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid);
      return isSignedIn() && 
             exists(memberPath) && 
             (get(memberPath).data.get('role', 'none') in roles);
    }

    function isParentOf(centerId, studentId) {
      let memberPath = /databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid);
      return isSignedIn() && 
             exists(memberPath) && 
             get(memberPath).data.get('role', 'none') == 'parent' && 
             studentId in get(memberPath).data.get('linkedStudentIds', []);
    }

    // --- 컬렉션 규칙 ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /centers/{centerId} {
      // 센터 기본 정보는 인증된 사용자라면 누구나 읽기 가능
      allow read: if isSignedIn();

      match /members/{memberId} {
        allow read: if isSignedIn() && (request.auth.uid == memberId || hasRole(centerId, ['centerAdmin', 'teacher']));
      }

      // 상담 예약 (Appointments)
      match /appointments/{appointmentId} {
        // 읽기 권한: 본인, 담당 교사, 관리자, 또는 연결된 학부모
        // resource.data 가 없는 경우(list 쿼리 시작 등)에도 안전하게 평가되도록 함
        allow read: if isSignedIn() && (
          (resource == null) || 
          (resource.data.studentId == request.auth.uid) ||
          (resource.data.teacherId == request.auth.uid) ||
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          isParentOf(centerId, resource.data.studentId)
        );
        
        // 생성 권한: 학생 본인, 부모, 또는 관리자/교사
        allow create: if isSignedIn() && (
          (request.resource.data.studentId == request.auth.uid) ||
          isParentOf(centerId, request.resource.data.studentId) ||
          hasRole(centerId, ['centerAdmin', 'teacher'])
        );
        
        // 수정 권한: 상태 변경 및 관리
        allow update: if isSignedIn() && (
          // 학생은 본인 예약의 상태를 'cancelled'로만 변경 가능
          (resource.data.studentId == request.auth.uid && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
           request.resource.data.status == 'cancelled') ||
          // 교사/관리자는 담당 예약 수정 가능
          (hasRole(centerId, ['centerAdmin', 'teacher']))
        );
      }

      // 상담일지 (Counseling Notes)
      match /counselingNotes/{noteId} {
        allow read: if isSignedIn() && (
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          (resource.data.visibility == 'student_and_parent' && 
           (request.auth.uid == resource.data.studentId || isParentOf(centerId, resource.data.studentId)))
        );
        allow write: if isSignedIn() && hasRole(centerId, ['centerAdmin', 'teacher']);
      }

      // 성장 트리 진행도
      match /growthProgress/{userId} {
        allow read: if isSignedIn() && (
          request.auth.uid == userId || 
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          isParentOf(centerId, userId)
        );
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      // 일일 통계
      match /dailyStudentStats/{date}/students/{studentId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId || 
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          isParentOf(centerId, studentId)
        );
      }

      // 학습 로그
      match /studyLogs/{studentId}/days/{date} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId || 
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          isParentOf(centerId, studentId)
        );
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      // 출석 기록
      match /attendanceRecords/{date}/students/{studentId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId || 
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          isParentOf(centerId, studentId)
        );
        allow write: if hasRole(centerId, ['centerAdmin', 'teacher']);
      }

      // 학습 계획
      match /plans/{studentId}/weeks/{week}/items/{itemId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId || 
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          isParentOf(centerId, studentId)
        );
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      // AI 및 기타 기록
      match /records/{recordId} {
        allow read: if isSignedIn() && (
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          resource.data.studentId == request.auth.uid ||
          isParentOf(centerId, resource.data.studentId)
        );
        allow write: if false; 
      }
    }

    match /inviteCodes/{code} {
      allow get: if isSignedIn();
    }

    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    // 컬렉션 그룹 쿼리 지원
    match /{path=**}/records/{recordId} {
      allow read: if isSignedIn() && (
        hasRole(resource.data.centerId, ['centerAdmin', 'teacher']) ||
        resource.data.studentId == request.auth.uid ||
        isParentOf(resource.data.centerId, resource.data.studentId)
      );
    }
  }
}
