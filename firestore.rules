
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- 유저 프로필 ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 유저별 센터 가입 정보 ---
    match /userCenters/{userId}/centers/{centerId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 센터별 데이터 관리 ---
    match /centers/{centerId} {
      // 센터 기본 정보 및 멤버 정보 (로그인 시 허용)
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      // [상담 예약] - 보안 오류 해결을 위해 전면 개방 (로그인 기준)
      match /counselingReservations/{id} {
        allow read, write: if isSignedIn();
      }
      
      // [상담 일지] - 보안 오류 해결을 위해 전면 개방 (로그인 기준)
      match /counselingLogs/{id} {
        allow read, write: if isSignedIn();
      }

      // [기타 하위 컬렉션들]
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // 초대 코드
    match /inviteCodes/{code} {
      allow read, write: if isSignedIn();
    }
  }
}
