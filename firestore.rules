rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getMember(centerId, uid) {
      return get(/databases/$(database)/documents/centers/$(centerId)/members/$(uid)).data;
    }

    function hasRole(centerId, roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid)) &&
             getMember(centerId, request.auth.uid).role in roles;
    }

    // --- 컬렉션 규칙 ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    match /centers/{centerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // 센터 생성 허용

      // 멤버 정보 (가입 시 본인 문서 작성 허용)
      match /members/{memberId} {
        allow read: if isSignedIn() && (request.auth.uid == memberId || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow create, write: if isSignedIn() && (request.auth.uid == memberId || hasRole(centerId, ['centerAdmin'])); 
      }

      // 학생 프로필
      match /students/{studentId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow write: if hasRole(centerId, ['teacher', 'centerAdmin']);
      }

      // 성장 로드맵
      match /growthProgress/{uid} {
        allow read: if isSignedIn() && (request.auth.uid == uid || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow create, write: if isSignedIn() && request.auth.uid == uid;
      }
      
      // 상담 예약
      match /counselingReservations/{resId} {
        allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow create: if isSignedIn();
        allow update: if hasRole(centerId, ['teacher', 'centerAdmin']) || (isSignedIn() && resource.data.studentId == request.auth.uid);
      }

      // 상담 일지
      match /counselingLogs/{logId} {
        allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow create: if hasRole(centerId, ['teacher', 'centerAdmin']);
        allow update: if hasRole(centerId, ['centerAdmin']) || (hasRole(centerId, ['teacher']) && resource.data.teacherId == request.auth.uid);
      }
    }

    // 사용자 멤버십 역인덱스 (가입 시 본인 문서 작성 허용)
    match /userCenters/{userId} {
      allow read, list: if isSignedIn() && request.auth.uid == userId;
      match /centers/{centerId} {
        allow read, create, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 초대 코드
    match /inviteCodes/{code} {
      allow get: if isSignedIn();
    }
  }
}