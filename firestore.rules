
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- [상담 시스템 전면 개방] ---
    // 로그인만 되어 있다면 센터 내 상담 예약 및 일지를 자유롭게 읽고 쓸 수 있도록 허용합니다.
    match /centers/{centerId}/counselingReservations/{id} {
      allow read, write: if isSignedIn();
    }

    match /centers/{centerId}/counselingLogs/{id} {
      allow read, write: if isSignedIn();
    }

    // --- 유저 프로필 ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 유저별 센터 가입 정보 ---
    match /userCenters/{userId}/centers/{centerId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 센터별 데이터 관리 ---
    match /centers/{centerId} {
      // 센터 기본 정보 및 멤버 정보
      allow read, write: if isSignedIn();
      
      // 기타 하위 컬렉션들 (출석, 성적 등)
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // 초대 코드
    match /inviteCodes/{code} {
      allow read, write: if isSignedIn();
    }
  }
}
