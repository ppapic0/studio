
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getMembership(centerId) {
      return get(/databases/$(database)/documents/userCenters/$(request.auth.uid)/centers/$(centerId)).data;
    }

    function isCenterMember(centerId) {
      return isSignedIn() && exists(/databases/$(database)/documents/userCenters/$(request.auth.uid)/centers/$(centerId));
    }

    function isStaff(centerId) {
      return isCenterMember(centerId) && getMembership(centerId).role in ['teacher', 'centerAdmin'];
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn();
    }

    match /centers/{centerId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();

      match /members/{memberId} {
        allow read: if isCenterMember(centerId);
        allow list: if isStaff(centerId) || (isSignedIn() && request.auth.uid == memberId);
        allow write: if isSignedIn();
      }

      match /students/{studentId} {
        allow read: if isCenterMember(centerId);
        allow write: if isStaff(centerId) || (isSignedIn() && request.auth.uid == studentId);
      }

      match /dailyStudentStats/{date}/students/{studentId} {
        allow read: if isStaff(centerId) || (isSignedIn() && request.auth.uid == studentId);
        allow write: if isStaff(centerId);
      }
      
      match /dailyReports/{reportId} {
        allow read: if isStaff(centerId) || (isSignedIn() && request.auth.uid == resource.data.studentId);
        allow write: if isStaff(centerId);
      }

      match /studyLogs/{studentId}/days/{date} {
        allow read: if isStaff(centerId) || (isSignedIn() && request.auth.uid == studentId);
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /plans/{studentId}/weeks/{week}/items/{itemId} {
        allow read: if isStaff(centerId) || (isSignedIn() && request.auth.uid == studentId);
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /growthProgress/{studentId} {
        allow read: if isStaff(centerId) || (isSignedIn() && request.auth.uid == studentId);
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /leaderboards/{leaderboardId}/entries/{studentId} {
        allow read: if isCenterMember(centerId);
        allow write: if isStaff(centerId);
      }

      match /counselingReservations/{resId} {
        allow read: if isCenterMember(centerId);
        allow write: if isCenterMember(centerId);
      }
      match /counselingLogs/{logId} {
        allow read: if isCenterMember(centerId);
        allow write: if isStaff(centerId);
      }

      match /attendanceRecords/{date}/students/{studentId} {
        allow read: if isCenterMember(centerId);
        allow write: if isStaff(centerId);
      }
      match /attendanceCurrent/{seatId} {
        allow read: if isCenterMember(centerId);
        allow write: if isStaff(centerId) || (isSignedIn() && seatId.hasPrefix('seat_'));
      }
    }

    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
