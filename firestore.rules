rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getMember(centerId, uid) {
      return get(/databases/$(database)/documents/centers/$(centerId)/members/$(uid)).data;
    }

    function hasRole(centerId, roles) {
      return isSignedIn() && getMember(centerId, request.auth.uid).role in roles;
    }

    // --- 컬렉션 규칙 ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /centers/{centerId} {
      allow read: if isSignedIn();

      // 멤버 정보
      match /members/{memberId} {
        allow read: if isSignedIn() && (request.auth.uid == memberId || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow write: if hasRole(centerId, ['centerAdmin']);
      }

      // 학생 프로필 (Teacher 전용)
      match /students/{studentId} {
        allow read, write: if hasRole(centerId, ['teacher', 'centerAdmin']);
      }

      // 현재 출결/좌석 상태 (Teacher 전용)
      match /attendanceCurrent/{studentId} {
        allow read, write: if hasRole(centerId, ['teacher', 'centerAdmin']);
      }

      // 공부 계획 (Teacher/Admin 관리)
      match /studyPlans/{planId} {
        allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow create: if hasRole(centerId, ['teacher', 'centerAdmin']);
        allow update: if hasRole(centerId, ['teacher', 'centerAdmin']) && (resource.data.teacherId == request.auth.uid || hasRole(centerId, ['centerAdmin']));
      }

      // 상담 일지
      match /counselingLogs/{logId} {
        allow read: if hasRole(centerId, ['teacher', 'centerAdmin']);
        allow create: if hasRole(centerId, ['teacher', 'centerAdmin']);
        allow update: if hasRole(centerId, ['teacher', 'centerAdmin']) && (resource.data.teacherId == request.auth.uid || hasRole(centerId, ['centerAdmin']));
      }

      // 학부모 피드백 초안
      match /parentFeedbackDrafts/{draftId} {
        allow read, write: if hasRole(centerId, ['teacher', 'centerAdmin']);
      }

      // 기존 하위 호환성 유지용 규칙들
      match /appointments/{appointmentId} {
        allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow create: if isSignedIn() && (request.resource.data.studentId == request.auth.uid || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow update: if isSignedIn() && ((resource.data.studentId == request.auth.uid && request.resource.data.status == 'cancelled') || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow delete: if hasRole(centerId, ['teacher', 'centerAdmin']);
      }

      match /plans/{studentId}/weeks/{weekId}/items/{itemId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /studyLogs/{studentId}/days/{date} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /growthProgress/{userId} {
        allow read: if isSignedIn() && (userId == request.auth.uid || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow write: if isSignedIn() && userId == request.auth.uid;
      }
    }

    match /inviteCodes/{code} {
      allow get: if isSignedIn();
    }

    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    // 메시지 큐 (서버 전송용)
    match /messageQueue/{messageId} {
      allow read: if hasRole(request.resource.data.centerId, ['teacher', 'centerAdmin']);
      allow create: if isSignedIn() && hasRole(request.resource.data.centerId, ['teacher', 'centerAdmin']);
      allow update: if false; // 서버(Admin SDK)에서만 업데이트 권장
    }
  }
}
