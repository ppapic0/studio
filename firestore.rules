
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getRole(centerId) {
      return get(/databases/$(database)/documents/userCenters/$(request.auth.uid)/centers/$(centerId)).data.role;
    }

    function isMember(centerId) {
      return isSignedIn() && exists(/databases/$(database)/documents/userCenters/$(request.auth.uid)/centers/$(centerId));
    }

    function isStaff(centerId) {
      return isMember(centerId) && getRole(centerId) in ['teacher', 'centerAdmin'];
    }

    // --- [CRITICAL] 선생님/관리자 전능 권한 (Owner) ---
    // 센터 내의 모든 데이터는 스태프라면 무조건 읽고 쓸 수 있음
    match /centers/{centerId}/{allSubcollections=**} {
      allow read, write: if isStaff(centerId);
    }

    // --- 유저 프로필 ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isStaff('learning-lab-dongbaek'));
    }

    // --- 유저별 센터 역인덱스 ---
    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff(centerId));
      allow write: if isSignedIn();
    }

    // --- 초대 코드 ---
    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- 개별 접근 규칙 (학생용) ---
    match /centers/{centerId} {
      allow read: if isMember(centerId);
      
      match /members/{memberId} {
        allow read: if isMember(centerId) && (request.auth.uid == memberId);
      }

      match /students/{studentId} {
        allow read: if isMember(centerId);
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /plans/{studentId}/weeks/{week}/items/{itemId} {
        allow read: if isSignedIn() && request.auth.uid == studentId;
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /studyLogs/{studentId}/days/{date} {
        allow read: if isSignedIn() && request.auth.uid == studentId;
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /growthProgress/{studentId} {
        allow read: if isSignedIn() && request.auth.uid == studentId;
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }
    }

    // --- 기타 시스템 와일드카드 (최후의 보루) ---
    match /{document=**} {
      allow read, write: if isSignedIn() && isStaff('learning-lab-dongbaek');
    }
  }
}
