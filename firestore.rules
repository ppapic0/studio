rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function memberPath(centerId) {
      return /databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid);
    }

    function userCenterPath(centerId) {
      return /databases/$(database)/documents/userCenters/$(request.auth.uid)/centers/$(centerId);
    }

    function hasMembership(centerId) {
      return isSignedIn() && exists(memberPath(centerId));
    }

    function hasUserCenter(centerId) {
      return isSignedIn() && exists(userCenterPath(centerId));
    }

    function getMemberRole(centerId) {
      // members 문서가 존재하고 role 필드가 null이 아닌 경우에만 사용,
      // 그렇지 않으면 userCenters 문서로 폴백 (클라이언트 우선순위와 일치)
      return hasMembership(centerId)
        ? (get(memberPath(centerId)).data.role != null
            ? get(memberPath(centerId)).data.role
            : (hasUserCenter(centerId) ? get(userCenterPath(centerId)).data.role : null))
        : (hasUserCenter(centerId) ? get(userCenterPath(centerId)).data.role : null);
    }

    function getMemberStatus(centerId) {
      return hasMembership(centerId)
        ? get(memberPath(centerId)).data.status
        : (hasUserCenter(centerId) ? get(userCenterPath(centerId)).data.status : null);
    }

    function isActiveStatus(status) {
      return status == null || status == '' || status == 'active' || status == 'ACTIVE';
    }

    function isActiveMember(centerId) {
      return isActiveStatus(getMemberStatus(centerId));
    }

    function isRoleCenterAdmin(role) {
      return role == 'centerAdmin' || role == 'owner' || role == 'centerManager' || role == 'admin';
    }

    function isCenterAdminRole(role) {
      return isRoleCenterAdmin(role);
    }

    function isCenterAdmin(centerId) {
      return isActiveMember(centerId) && isRoleCenterAdmin(getMemberRole(centerId));
    }

    function isRoleTeacherOrAdmin(role) {
      return role == 'teacher' || isRoleCenterAdmin(role);
    }

    function isTeacherOrAdmin(centerId) {
      return isActiveMember(centerId) && isRoleTeacherOrAdmin(getMemberRole(centerId));
    }

    function isTeacher(centerId) {
      return isActiveMember(centerId) && getMemberRole(centerId) == 'teacher';
    }

    function canTeacherCreateWebsiteLead(centerId) {
      return isTeacher(centerId)
        && request.resource.data.source == 'website'
        && request.resource.data.sourceRequestId is string
        && request.resource.data.sourceRequestId != ''
        && request.resource.data.createdByUid == request.auth.uid;
    }

    function canTeacherLinkLeadToWaitlist(centerId) {
      return isTeacher(centerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['addedToWaitlistId', 'addedToWaitlistIds', 'updatedAt']);
    }

    function canTeacherLinkWebsiteRequestToLead(centerId) {
      return isTeacher(centerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedLeadId', 'updatedAt']);
    }

    function canTeacherCreateWaitlistFromLead(centerId) {
      return isTeacher(centerId)
        && request.resource.data.sourceLeadId is string
        && request.resource.data.sourceLeadId != '';
    }

    function canTeacherAttachWebsiteWaitlistToLead(centerId) {
      return isTeacher(centerId)
        && resource.data.sourceWebsiteRequestId != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sourceLeadId', 'studentName', 'parentPhone', 'school', 'grade', 'updatedAt']);
    }

    function isStudent(centerId) {
      return getMemberRole(centerId) == 'student';
    }

    function isParent(centerId) {
      return getMemberRole(centerId) == 'parent';
    }

    function isSelfStudent(studentId) {
      return isSignedIn() && request.auth.uid == studentId;
    }

    function isSelfCenterMember(centerId, studentId) {
      return isSelfStudent(studentId) && (hasMembership(centerId) || hasUserCenter(centerId));
    }

    function isLinkedParentFromMember(centerId, studentId) {
      return hasMembership(centerId)
        && get(memberPath(centerId)).data.linkedStudentIds != null
        && get(memberPath(centerId)).data.linkedStudentIds.hasAny([studentId]);
    }

    function isLinkedParentFromUserCenter(centerId, studentId) {
      return hasUserCenter(centerId)
        && get(userCenterPath(centerId)).data.linkedStudentIds != null
        && get(userCenterPath(centerId)).data.linkedStudentIds.hasAny([studentId]);
    }

    function isLinkedParent(centerId, studentId) {
      return isParent(centerId)
        && (isLinkedParentFromMember(centerId, studentId) || isLinkedParentFromUserCenter(centerId, studentId));
    }

    function isLinkedParentFromResource(centerId) {
      return isParent(centerId)
        && resource.data.studentId != null
        && isLinkedParent(centerId, resource.data.studentId);
    }

    function isLinkedParentFromRequest(centerId) {
      return isParent(centerId)
        && request.resource.data.studentId != null
        && isLinkedParent(centerId, request.resource.data.studentId);
    }

    function parentCommunicationPath(centerId, communicationId) {
      return /databases/$(database)/documents/centers/$(centerId)/parentCommunications/$(communicationId);
    }

    function isStudentOwnedCommunication(centerId, communicationId, studentId) {
      return communicationId is string
        && communicationId != ''
        && exists(parentCommunicationPath(centerId, communicationId))
        && get(parentCommunicationPath(centerId, communicationId)).data.senderRole == 'student'
        && get(parentCommunicationPath(centerId, communicationId)).data.senderUid == studentId
        && get(parentCommunicationPath(centerId, communicationId)).data.studentId == studentId;
    }

    function isAllowedSelfStudyLogDayCreate(centerId, studentId, dateKey) {
      return isSelfCenterMember(centerId, studentId)
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.centerId == centerId
        && request.resource.data.dateKey == dateKey
        && request.resource.data.keys().hasOnly([
          'studentId',
          'centerId',
          'dateKey',
          'firstSessionStartAt',
          'lastSessionEndAt',
          'awayMinutes',
          'updatedAt',
        ]);
    }

    function isAllowedSelfStudyLogDayUpdate(centerId, studentId, dateKey) {
      return isSelfCenterMember(centerId, studentId)
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.centerId == centerId
        && request.resource.data.dateKey == dateKey
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'studentId',
          'centerId',
          'dateKey',
          'firstSessionStartAt',
          'lastSessionEndAt',
          'awayMinutes',
          'updatedAt',
        ]);
    }

    function isAllowedSelfGrowthProgressUpdate(centerId, studentId) {
      return (
        isSelfCenterMember(centerId, studentId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'pointsBalance',
          'totalPointsEarned',
          'penaltyPoints',
          'seasonLp',
          'stats',
        ])
      ) || (
        isSelfCenterMember(centerId, studentId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'pointsBalance',
          'totalPointsEarned',
          'dailyPointStatus',
          'updatedAt',
        ])
        && request.resource.data.pointsBalance >= resource.data.pointsBalance
        && request.resource.data.totalPointsEarned >= resource.data.totalPointsEarned
        && request.resource.data.pointsBalance - resource.data.pointsBalance
          == request.resource.data.totalPointsEarned - resource.data.totalPointsEarned
        && request.resource.data.pointsBalance - resource.data.pointsBalance <= 40
      );
    }

    function isAllowedSelfStudySessionCreate(centerId, studentId, dateKey, sessionId) {
      return isSelfCenterMember(centerId, studentId)
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.centerId == centerId
        && request.resource.data.dateKey == dateKey
        && request.resource.data.sessionId == sessionId
        && request.resource.data.startTime is timestamp
        && request.resource.data.endTime is timestamp
        && request.resource.data.durationMinutes is int
        && request.resource.data.durationMinutes >= 1
        && request.resource.data.durationMinutes <= 360
        && request.resource.data.endTime >= request.resource.data.startTime
        && request.resource.data.keys().hasOnly([
          'centerId',
          'studentId',
          'dateKey',
          'startTime',
          'endTime',
          'durationMinutes',
          'sessionId',
          'createdAt',
        ]);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /schedules/{dateKey} {
        allow read: if (isSignedIn() && request.auth.uid == userId)
          || (resource.data.centerId != null && isTeacherOrAdmin(resource.data.centerId));
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.dateKey == dateKey;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /scheduleTemplates/{templateId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /plannerDiagnostics/{diagnosisId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /studyPlans/{weekKey} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /inviteCodes/{code} {
      allow read: if isSignedIn()
        && resource.data.centerId != null
        && isCenterAdmin(resource.data.centerId);
      allow create: if isSignedIn()
        && request.resource.data.centerId != null
        && isCenterAdmin(request.resource.data.centerId);
      allow update: if isSignedIn()
        && resource.data.centerId != null
        && isCenterAdmin(resource.data.centerId);
      allow delete: if isSignedIn()
        && resource.data.centerId != null
        && isCenterAdmin(resource.data.centerId);
    }

    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /centers/{centerId} {
      allow read: if isActiveMember(centerId);
      allow write: if isCenterAdmin(centerId);

      match /members/{memberId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isSignedIn() && request.auth.uid == memberId)
          || (isActiveMember(centerId) && resource.data.role in ['teacher', 'centerAdmin', 'owner'])
          || (isStudent(centerId) && resource.data.role == 'student' && isActiveStatus(resource.data.status));
        allow create, update, delete: if isCenterAdmin(centerId);
      }

      match /students/{studentId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isSignedIn() && request.auth.uid == studentId)
          || isLinkedParent(centerId, studentId);
        allow create, update: if isTeacherOrAdmin(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /growthProgress/{studentId} {
        allow read: if isTeacherOrAdmin(centerId)
          || isSelfStudent(studentId)
          || isLinkedParent(centerId, studentId);
        allow create: if isTeacherOrAdmin(centerId);
        allow update: if isTeacherOrAdmin(centerId)
          || isAllowedSelfGrowthProgressUpdate(centerId, studentId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /attendanceCurrent/{seatId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isSignedIn()
              && resource.data.studentId != null
              && resource.data.studentId == request.auth.uid)
          || isLinkedParentFromResource(centerId);
        allow create: if isTeacherOrAdmin(centerId)
          || (isSignedIn()
              && isSelfCenterMember(centerId, request.auth.uid)
              && request.resource.data.studentId == request.auth.uid);
        allow update: if isTeacherOrAdmin(centerId)
          || (isSignedIn()
              && isSelfCenterMember(centerId, request.auth.uid)
              && ((resource.data.studentId != null && resource.data.studentId == request.auth.uid)
                || (request.resource.data.studentId != null && request.resource.data.studentId == request.auth.uid)));
        allow delete: if isCenterAdmin(centerId);
      }

      match /studyLogs/{studentId} {
        allow read: if isTeacherOrAdmin(centerId)
          || isSelfCenterMember(centerId, studentId)
          || isLinkedParent(centerId, studentId);
        allow create, update: if isTeacherOrAdmin(centerId)
          || isSelfCenterMember(centerId, studentId);
        allow delete: if isCenterAdmin(centerId);

        match /days/{dateKey} {
          allow read: if isTeacherOrAdmin(centerId)
            || isSelfCenterMember(centerId, studentId)
            || isLinkedParent(centerId, studentId);
          allow create: if isTeacherOrAdmin(centerId)
            || isAllowedSelfStudyLogDayCreate(centerId, studentId, dateKey);
          allow update: if isTeacherOrAdmin(centerId)
            || isAllowedSelfStudyLogDayUpdate(centerId, studentId, dateKey);
          allow delete: if isCenterAdmin(centerId);

          match /sessions/{sessionId} {
            allow read: if isTeacherOrAdmin(centerId)
              || isSelfCenterMember(centerId, studentId)
              || isLinkedParent(centerId, studentId);
            allow create: if isTeacherOrAdmin(centerId)
              || isAllowedSelfStudySessionCreate(centerId, studentId, dateKey, sessionId);
            allow update: if isTeacherOrAdmin(centerId);
            allow delete: if isCenterAdmin(centerId);
          }
        }
      }

      match /plans/{studentId}/weeks/{weekKey}/items/{itemId} {
        allow read: if isTeacherOrAdmin(centerId)
          || isSelfCenterMember(centerId, studentId)
          || isLinkedParent(centerId, studentId);
        allow create, update: if isTeacherOrAdmin(centerId)
          || isSelfCenterMember(centerId, studentId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /parentAiCache/{studentId}/days/{dateKey} {
        allow read: if isTeacherOrAdmin(centerId) || isLinkedParent(centerId, studentId);
        allow write: if isTeacherOrAdmin(centerId) || isLinkedParent(centerId, studentId);
      }

      match /dailyStudentStats/{dateKey}/students/{studentId} {
        allow read: if isTeacherOrAdmin(centerId)
          || isSelfCenterMember(centerId, studentId)
          || isLinkedParent(centerId, studentId);
        allow create, update: if isTeacherOrAdmin(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /classroomSignals/{dateKey} {
        allow read: if isTeacherOrAdmin(centerId);
        allow write: if isCenterAdmin(centerId);
      }

      match /attendanceRecords/{dateKey}/students/{studentId} {
        allow read: if isTeacherOrAdmin(centerId)
          || isSelfCenterMember(centerId, studentId)
          || isLinkedParent(centerId, studentId);
        allow create, update: if isTeacherOrAdmin(centerId)
          || (isSelfCenterMember(centerId, studentId)
              && request.resource.data.studentId == request.auth.uid
              && request.resource.data.dateKey == dateKey
              && request.resource.data.centerId == centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /attendanceDailyStats/{dateKey}/students/{studentId} {
        allow read: if isTeacherOrAdmin(centerId)
          || isSelfCenterMember(centerId, studentId)
          || isLinkedParent(centerId, studentId);
        allow create, update: if isTeacherOrAdmin(centerId)
          || (isSelfCenterMember(centerId, studentId)
              && request.resource.data.studentId == request.auth.uid
              && request.resource.data.dateKey == dateKey
              && request.resource.data.centerId == centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /attendanceEvents/{eventId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid);
        allow create, update: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && request.resource.data.studentId == request.auth.uid);
        allow delete: if isCenterAdmin(centerId);
      }

      match /kpiDaily/{dateKey} {
        allow read, write: if isCenterAdmin(centerId);
      }

      match /invoices/{invoiceId} {
        allow read: if isCenterAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid)
          || isLinkedParentFromResource(centerId);
        allow write: if isCenterAdmin(centerId);
      }

      match /payments/{paymentId} {
        allow read: if isCenterAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid)
          || isLinkedParentFromResource(centerId);
        allow write: if isCenterAdmin(centerId);
      }

      match /billingProfiles/{studentId} {
        allow read, write: if isCenterAdmin(centerId);
      }

      match /dailyReports/{reportId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid)
          || isLinkedParentFromResource(centerId);
        allow create: if isTeacherOrAdmin(centerId);
        allow update: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId)
              && resource.data.studentId == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedAt']))
          || (isLinkedParentFromResource(centerId)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedAt', 'updatedAt']));
        allow delete: if isCenterAdmin(centerId);
      }

      match /centerAnnouncements/{announcementId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isSignedIn() && (hasMembership(centerId) || hasUserCenter(centerId)));
        allow create, update: if isTeacherOrAdmin(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /counselingReservations/{resId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isSignedIn() && (resource.data.studentId == request.auth.uid || resource.data.teacherId == request.auth.uid))
          || isLinkedParentFromResource(centerId);
        allow create: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && request.resource.data.studentId == request.auth.uid)
          || isLinkedParentFromRequest(centerId);
        allow update: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid)
          || isLinkedParentFromResource(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /counselingLogs/{logId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid)
          || isLinkedParentFromResource(centerId);
        allow create, update: if isTeacherOrAdmin(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /attendanceRequests/{reqId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid)
          || isLinkedParentFromResource(centerId);
        allow create: if isTeacherOrAdmin(centerId);
        allow update: if isTeacherOrAdmin(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /penaltyLogs/{logId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid)
          || isLinkedParentFromResource(centerId);
        allow create: if isTeacherOrAdmin(centerId);
        allow update: if isTeacherOrAdmin(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /parentNotifications/{notificationId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isParent(centerId) && resource.data.parentUid == request.auth.uid);
        allow create, update: if isTeacherOrAdmin(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /studentNotifications/{notificationId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid)
          || isLinkedParentFromResource(centerId);
        allow create: if isTeacherOrAdmin(centerId);
        allow update: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId)
              && resource.data.studentId == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt', 'updatedAt']));
        allow delete: if isCenterAdmin(centerId);
      }

      match /parentCommunications/{commId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isParent(centerId) && resource.data.parentUid == request.auth.uid)
          || (isStudent(centerId)
              && resource.data.senderRole == 'student'
              && resource.data.senderUid == request.auth.uid
              && resource.data.studentId == request.auth.uid);
        allow create: if (isLinkedParentFromRequest(centerId)
            && request.resource.data.parentUid == request.auth.uid)
          || (isStudent(centerId)
              && request.resource.data.studentId == request.auth.uid
              && request.resource.data.senderRole == 'student'
              && request.resource.data.senderUid == request.auth.uid
              && request.resource.data.type in ['request', 'suggestion']);
        allow update: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId)
              && resource.data.senderRole == 'student'
              && resource.data.senderUid == request.auth.uid
              && resource.data.studentId == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'latestMessageAt', 'latestMessagePreview', 'status'])
              && request.resource.data.status == 'requested');
        allow delete: if isCenterAdmin(centerId);
      }

      match /supportMessages/{messageId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid)
          || (isParent(centerId) && resource.data.parentUid == request.auth.uid);
        allow create: if (isTeacherOrAdmin(centerId)
            && request.resource.data.centerId == centerId
            && request.resource.data.communicationId is string
            && request.resource.data.communicationId != ''
            && request.resource.data.studentId != null
            && exists(parentCommunicationPath(centerId, request.resource.data.communicationId))
            && get(parentCommunicationPath(centerId, request.resource.data.communicationId)).data.studentId == request.resource.data.studentId
            && request.resource.data.senderUid == request.auth.uid
            && request.resource.data.senderRole in ['teacher', 'centerAdmin'])
          || (isStudent(centerId)
              && request.resource.data.centerId == centerId
              && request.resource.data.studentId == request.auth.uid
              && isStudentOwnedCommunication(centerId, request.resource.data.communicationId, request.auth.uid)
              && request.resource.data.senderUid == request.auth.uid
              && request.resource.data.senderRole == 'student');
        allow update: if false;
        allow delete: if isCenterAdmin(centerId);
      }

      match /parentActivityEvents/{eventId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isParent(centerId) && resource.data.parentUid == request.auth.uid);
        allow create: if isLinkedParentFromRequest(centerId)
          && request.resource.data.parentUid == request.auth.uid
          && request.resource.data.eventType in ['app_visit', 'report_read', 'consultation_request', 'request', 'suggestion'];
        allow update, delete: if false;
      }

      match /consultingLeads/{leadId} {
        allow read: if isTeacherOrAdmin(centerId);
        allow create: if isCenterAdmin(centerId) || canTeacherCreateWebsiteLead(centerId);
        allow update: if isCenterAdmin(centerId) || canTeacherLinkLeadToWaitlist(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /admissionWaitlist/{entryId} {
        allow read: if isTeacherOrAdmin(centerId);
        allow create: if isCenterAdmin(centerId) || canTeacherCreateWaitlistFromLead(centerId);
        allow update: if isCenterAdmin(centerId) || canTeacherAttachWebsiteWaitlistToLead(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /websiteConsultRequests/{reqId} {
        allow read: if isTeacherOrAdmin(centerId);
        allow create: if isCenterAdmin(centerId);
        allow update: if isCenterAdmin(centerId) || canTeacherLinkWebsiteRequestToLead(centerId);
        allow delete: if isCenterAdmin(centerId);
      }

      match /websiteEntryEvents/{eventId} {
        allow read: if isTeacherOrAdmin(centerId);
        allow write: if isCenterAdmin(centerId);
      }

      match /smsDeliveryLogs/{logId} {
        allow read: if isTeacherOrAdmin(centerId);
        allow write: if isCenterAdmin(centerId);
      }

      match /settings/{settingId} {
        allow read, write: if isCenterAdmin(centerId);
      }

      match /settingsPrivate/{settingId} {
        allow read, write: if false;
      }

      match /integrations/{integrationId} {
        allow read, write: if isCenterAdmin(centerId);
      }

      match /giftishowProducts/{productId} {
        allow read: if isActiveMember(centerId);
        allow write: if isCenterAdmin(centerId);
      }

      match /giftishowBrands/{brandId} {
        allow read: if isActiveMember(centerId);
        allow write: if isCenterAdmin(centerId);
      }

      match /giftishowOrders/{orderId} {
        allow read: if isTeacherOrAdmin(centerId)
          || (isStudent(centerId) && resource.data.studentId == request.auth.uid)
          || isLinkedParentFromResource(centerId);
        allow write: if isCenterAdmin(centerId);
      }

      match /leaderboards/{boardId}/entries/{entryId} {
        allow read: if isActiveMember(centerId);
        allow create, update: if isCenterAdmin(centerId)
          || (boardId.matches('.*_lp$')
              && isSelfCenterMember(centerId, entryId)
              && request.resource.data.studentId == request.auth.uid);
        allow delete: if isCenterAdmin(centerId);
      }

      match /{document=**} {
        allow read, write: if isCenterAdmin(centerId);
      }
    }
  }
}
