
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    // 사용자의 센터 내 역할을 가져오는 함수 (get 호출 최소화)
    function getRole(centerId) {
      return get(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid)).data.role;
    }

    // --- 유저 프로필 ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 유저별 센터 가입 정보 ---
    match /userCenters/{userId}/centers/{centerId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 센터별 데이터 관리 ---
    match /centers/{centerId} {
      // 센터 기본 정보 조회 (멤버라면 허용)
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid));
      
      // [상담 예약]
      match /counselingReservations/{id} {
        // 읽기: 본인 데이터(studentId 일치)는 즉시 허용, 아니면 선생님/관리자 확인
        // list 요청 시 where('studentId', '==', auth.uid) 필터가 있으면 통과됨
        allow read: if isSignedIn() && (
          (resource != null && resource.data.studentId == request.auth.uid) || 
          getRole(centerId) in ['teacher', 'centerAdmin']
        );
        // 생성: 본인 ID로만 생성 가능
        allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
        // 수정/삭제: 본인 또는 선생님
        allow update, delete: if isSignedIn() && (
          (resource != null && resource.data.studentId == request.auth.uid) || 
          getRole(centerId) in ['teacher', 'centerAdmin']
        );
      }
      
      // [상담 일지]
      match /counselingLogs/{id} {
        // 읽기: 본인 데이터는 즉시 허용, 아니면 선생님/관리자 확인
        allow read: if isSignedIn() && (
          (resource != null && resource.data.studentId == request.auth.uid) || 
          getRole(centerId) in ['teacher', 'centerAdmin']
        );
        // 쓰기: 선생님/관리자만 가능
        allow write: if isSignedIn() && getRole(centerId) in ['teacher', 'centerAdmin'];
      }

      // [기타 관리 규칙]
      match /members/{memberId} {
        allow read: if isSignedIn();
      }
      match /students/{studentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == studentId || getRole(centerId) in ['teacher', 'centerAdmin']);
      }
      match /plans/{studentId}/weeks/{week}/items/{itemId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || getRole(centerId) in ['teacher', 'centerAdmin']);
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }
      match /studyLogs/{studentId}/days/{date} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || getRole(centerId) in ['teacher', 'centerAdmin']);
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }
      match /dailyStudentStats/{date}/students/{studentId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || (isSignedIn() && exists(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid)) && getRole(centerId) in ['teacher', 'centerAdmin', 'parent']));
      }
      match /dailyReports/{reportId} {
        allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || getRole(centerId) in ['teacher', 'centerAdmin']);
        allow write: if isSignedIn() && getRole(centerId) in ['teacher', 'centerAdmin'];
      }
      match /attendanceCurrent/{id} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && getRole(centerId) in ['teacher', 'centerAdmin'];
      }
      match /growthProgress/{studentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == studentId || getRole(centerId) in ['teacher', 'centerAdmin']);
      }
    }

    // 초대 코드
    match /inviteCodes/{code} {
      allow read, write: if isSignedIn();
    }
  }
}
