
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /centers/{centerId} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions 전용
      
      match /members/{userId} {
        allow read: if isOwner(userId) || (get(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid)).data.role in ['admin', 'teacher']);
        allow write: if false;
      }
    }

    match /inviteCodes/{code} {
      allow get: if isSignedIn();
      allow list, write: if false;
    }

    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }
    
    // 기존 데이터 구조 호환을 위한 임시 규칙 (필요 시 제거 가능)
    match /centers/{centerId}/inviteCodes/{code} {
      allow get: if isSignedIn();
    }
  }
}
