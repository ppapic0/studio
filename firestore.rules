rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================================================
     * Helpers
     * ========================================================= */
    function isSignedIn() {
      return request.auth != null;
    }

    function memberPath(centerId, uid) {
      return /databases/$(database)/documents/centers/$(centerId)/members/$(uid);
    }

    function memberDoc(centerId) {
      return get(memberPath(centerId, request.auth.uid));
    }

    function isActiveMember(centerId) {
      return isSignedIn()
        && exists(memberPath(centerId, request.auth.uid))
        && memberDoc(centerId).data.status == "active";
    }

    function role(centerId) {
      return isActiveMember(centerId) ? memberDoc(centerId).data.role : null;
    }

    function hasRole(centerId, roles) {
      return isActiveMember(centerId) && (role(centerId) in roles);
    }

    function isSelf(studentId) {
      return isSignedIn() && request.auth.uid == studentId;
    }

    function isLinkedParent(centerId, studentId) {
      return hasRole(centerId, ["parent"])
        && ("linkedStudentIds" in memberDoc(centerId).data)
        && (studentId in memberDoc(centerId).data.linkedStudentIds);
    }

    function canReadStudent(centerId, studentId) {
      return hasRole(centerId, ["centerAdmin", "teacher"])
        || isSelf(studentId)
        || isLinkedParent(centerId, studentId);
    }

    function canWriteStudentOwn(centerId, studentId) {
      return isActiveMember(centerId)
        && hasRole(centerId, ["student"])
        && isSelf(studentId);
    }

    /* =========================================================
     * Default deny
     * ========================================================= */
    match /{document=**} {
      allow read, write: if false;
    }

    /* =========================================================
     * Global: Users & User Centers
     * ========================================================= */
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }
    
    // Reverse index for fast membership lookup
    match /userCenters/{uid}/{document=**} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow write: if false; // Only server (Admin SDK) can write here
    }

    /* =========================================================
     * Centers
     * ========================================================= */
    match /centers/{centerId} {
      // Center doc readable by active members
      allow read: if isActiveMember(centerId);

      // Center creation: allow signed-in (or set false and do server-only)
      allow create: if isSignedIn();

      // Center updates: centerAdmin only
      allow update: if hasRole(centerId, ["centerAdmin"]);

      // Center delete: block from clients
      allow delete: if false;

      /* -------------------------
       * Members (single source of truth for roles)
       * ------------------------- */
      match /members/{uid} {
        // Only active center members can read membership docs
        allow read: if isActiveMember(centerId) && (
          request.auth.uid == uid || hasRole(centerId, ["teacher", "centerAdmin"])
        );

        // DEV-ONLY: Allow creating your own membership doc.
        // In PROD, this should be false and handled server-side.
        allow create: if isSignedIn() && request.auth.uid == uid;

        // Update membership: centerAdmin only (server can bypass via Admin SDK)
        allow update: if hasRole(centerId, ["centerAdmin"]) || (isSignedIn() && request.auth.uid == uid);

        allow delete: if false;
      }

      /* -------------------------
       * Invite Codes (issue by admin; redeem server-side)
       * ------------------------- */
      match /inviteCodes/{code} {
        // Admin can manage codes
        allow read: if hasRole(centerId, ["centerAdmin"]);
        allow create, update, delete: if hasRole(centerId, ["centerAdmin"]);
      }

      /* -------------------------
       * Students (profiles)
       * ------------------------- */
      match /students/{studentId} {
        allow read: if canReadStudent(centerId, studentId);

        // Safer default: student can update own profile, but creation is admin/teacher (or server)
        allow create: if hasRole(centerId, ["teacher", "centerAdmin"]) || isSelf(studentId);
        allow update: if canWriteStudentOwn(centerId, studentId) || hasRole(centerId, ["teacher", "centerAdmin"]);
        allow delete: if hasRole(centerId, ["centerAdmin"]);
      }

      /* -------------------------
       * Plans
       * /plans/{studentId}/weeks/{weekKey}/items/{itemId}
       * ------------------------- */
      match /plans/{studentId} {
        allow read: if canReadStudent(centerId, studentId);
        allow write: if false;

        match /weeks/{weekKey} {
          allow read: if canReadStudent(centerId, studentId);
          allow create, update, delete: if canWriteStudentOwn(centerId, studentId);

          match /items/{itemId} {
            allow read: if canReadStudent(centerId, studentId);
            allow create, update, delete: if canWriteStudentOwn(centerId, studentId);
          }
        }
      }

      /* -------------------------
       * Study Logs
       * /studyLogs/{studentId}/days/{dateKey}
       * ------------------------- */
      match /studyLogs/{studentId} {
        allow read: if canReadStudent(centerId, studentId);
        allow write: if false;

        match /days/{dateKey} {
          allow read: if canReadStudent(centerId, studentId);
          allow create, update, delete: if canWriteStudentOwn(centerId, studentId);
        }
      }

      /* -------------------------
       * Attendance (B 구조)
       * /attendance/{yyyy-mm-dd}/records/{studentId}
       * ------------------------- */
      match /attendance/{dateKey} {
        // allow read of the date node only to active members (mostly irrelevant)
        allow read: if isActiveMember(centerId);
        allow write: if false;

        match /records/{studentId} {
          allow read: if canReadStudent(centerId, studentId);

          // safest: teacher/admin writes only
          allow create, update, delete: if hasRole(centerId, ["teacher", "centerAdmin"]);
        }
      }

      /* -------------------------
       * Seats / Seat Assignments
       * ------------------------- */
      match /seats/{seatId} {
        allow read: if isActiveMember(centerId);
        allow create, update, delete: if hasRole(centerId, ["centerAdmin"]);
      }

      // /seatAssignments/{periodKey}/{studentId}
      match /seatAssignments/{periodKey}/{studentId} {
        allow read: if canReadStudent(centerId, studentId) || hasRole(centerId, ["centerAdmin", "teacher"]);
        allow create, update, delete: if hasRole(centerId, ["centerAdmin"]);
      }

      /* -------------------------
       * Enrollments
       * ------------------------- */
      match /enrollments/{studentId} {
        allow read: if canReadStudent(centerId, studentId) || hasRole(centerId, ["centerAdmin", "teacher"]);
        allow create, update, delete: if hasRole(centerId, ["centerAdmin"]);
      }

      /* -------------------------
       * Notification Prefs (per-user, per-center)
       * /notificationPrefs/{uid}
       * ------------------------- */
      match /notificationPrefs/{uid} {
        allow read, create, update, delete: if isSignedIn()
          && request.auth.uid == uid
          && isActiveMember(centerId);
      }
      
      /* -------------------------
       * Audit Logs (NO client writes)
       * ------------------------- */
      match /auditLogs/{logId} {
        allow read: if hasRole(centerId, ["centerAdmin"]);
        allow write: if false; // Admin SDK only
      }

      /* -------------------------
       * Read-only Aggregates (NO client writes)
       * ------------------------- */

      // Daily aggregates (recommend structure: /statsDaily/{dateKey}/students/{studentId})
      match /statsDaily/{dateKey}/{document=**} {
        allow read: if hasRole(centerId, ["centerAdmin", "teacher"]);
        allow write: if false;
      }

      // Leaderboards (readable by any active member)
      match /leaderboards/{periodKey}/{document=**} {
        allow read: if isActiveMember(centerId);
        allow write: if false;
      }

      // Center KPI stats (admin/teacher read)
      match /centerStats/{periodKey} {
        allow read: if hasRole(centerId, ["centerAdmin", "teacher"]);
        allow write: if false;
      }

      /* -------------------------
       * AI Outputs (NO client writes)
       * /aiOutputs/{studentId}/{docId}
       * ------------------------- */
      match /aiOutputs/{studentId}/{docId} {
        allow read: if canReadStudent(centerId, studentId) || hasRole(centerId, ["teacher", "centerAdmin"]);
        allow write: if false;
      }
    }
  }
}
