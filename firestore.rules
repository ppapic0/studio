rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    // 사용자의 역할을 역인덱스(userCenters)에서 가져옵니다.
    function getRole(centerId, uid) {
      return get(/databases/$(database)/documents/userCenters/$(uid)/centers/$(centerId)).data.role;
    }

    function hasRole(centerId, roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/userCenters/$(request.auth.uid)/centers/$(centerId)) &&
             getRole(centerId, request.auth.uid) in roles;
    }

    // --- 컬렉션 규칙 ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    match /centers/{centerId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn(); 

      // 멤버 정보
      match /members/{memberId} {
        // 선생님/관리자는 목록 조회가 가능함
        allow list: if isSignedIn() && hasRole(centerId, ['teacher', 'centerAdmin']);
        // 본인이거나 선생님/관리자면 단일 문서 조회가 가능함
        allow get: if isSignedIn() && (request.auth.uid == memberId || hasRole(centerId, ['teacher', 'centerAdmin']));
        // 본인 가입 또는 선생님/관리자의 멤버 관리
        allow create, write: if isSignedIn() && (request.auth.uid == memberId || hasRole(centerId, ['centerAdmin', 'teacher'])); 
      }

      // 실시간 출결 (좌석 도면용)
      match /attendanceCurrent/{docId} {
        allow read, list: if isSignedIn();
        allow write: if hasRole(centerId, ['teacher', 'centerAdmin']);
      }

      // 학생 상세 프로필
      match /students/{studentId} {
        allow read, list: if isSignedIn() && (request.auth.uid == studentId || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow create: if isSignedIn() && request.auth.uid == studentId; // 가입 시 본인 생성 허용
        allow update, write: if hasRole(centerId, ['teacher', 'centerAdmin']);
      }

      // 성장 로드맵
      match /growthProgress/{uid} {
        allow read: if isSignedIn() && (request.auth.uid == uid || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow create, write: if isSignedIn() && request.auth.uid == uid;
      }
      
      // 상담 예약
      match /counselingReservations/{resId} {
        allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow list: if isSignedIn() && (hasRole(centerId, ['teacher', 'centerAdmin']) || request.query.limit <= 100);
        allow create: if isSignedIn();
        allow update: if hasRole(centerId, ['teacher', 'centerAdmin']) || (isSignedIn() && resource.data.studentId == request.auth.uid);
      }

      // 상담 일지
      match /counselingLogs/{logId} {
        allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow list: if isSignedIn() && hasRole(centerId, ['teacher', 'centerAdmin']);
        allow create: if hasRole(centerId, ['teacher', 'centerAdmin']);
        allow update: if hasRole(centerId, ['centerAdmin']) || (hasRole(centerId, ['teacher']) && resource.data.teacherId == request.auth.uid);
      }

      // 학부모 피드백 초안
      match /parentFeedbackDrafts/{draftId} {
        allow read, write: if hasRole(centerId, ['teacher', 'centerAdmin']);
      }

      // 학생별 세부 계획 경로
      match /plans/{studentId}/weeks/{weekId}/items/{itemId} {
        allow read, list: if isSignedIn() && (request.auth.uid == studentId || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow create, write: if isSignedIn() && request.auth.uid == studentId;
      }

      // 학습 로그
      match /studyLogs/{studentId}/days/{dateKey} {
        allow read, list: if isSignedIn() && (request.auth.uid == studentId || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow create, write: if isSignedIn() && request.auth.uid == studentId;
      }

      // 일일 학생 통계 (대시보드 지표)
      match /dailyStudentStats/{dateKey}/students/{studentId} {
        allow get, read: if isSignedIn() && (request.auth.uid == studentId || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow list: if isSignedIn() && hasRole(centerId, ['teacher', 'centerAdmin']);
      }

      // 출석 기록 (역사적 데이터)
      match /attendanceRecords/{dateKey}/students/{studentId} {
        allow read, get: if isSignedIn() && (request.auth.uid == studentId || hasRole(centerId, ['teacher', 'centerAdmin']));
        allow list: if isSignedIn() && hasRole(centerId, ['teacher', 'centerAdmin']);
        allow write: if hasRole(centerId, ['teacher', 'centerAdmin']);
      }

      // 리더보드
      match /leaderboards/{periodKey}/{metricType}/entries/{studentId} {
        allow read, list: if isSignedIn();
      }
    }

    // 사용자 멤버십 역인덱스 (AuthGuard 핵심 경로)
    match /userCenters/{userId} {
      allow read, list: if isSignedIn() && request.auth.uid == userId;
      match /centers/{centerId} {
        allow read, list, create, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 초대 코드
    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }
  }
}