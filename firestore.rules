rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(centerId, roles) {
      let memberPath = /databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid);
      return isSignedIn() && exists(memberPath) && (get(memberPath).data.role in roles);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /centers/{centerId} {
      allow read: if isSignedIn();

      match /members/{memberId} {
        allow read: if isSignedIn() && (request.auth.uid == memberId || hasRole(centerId, ['centerAdmin', 'teacher']));
      }

      // 성장 및 통계 데이터 규칙
      match /growthProgress/{userId} {
        allow read: if isSignedIn() && (
          request.auth.uid == userId || 
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          (hasRole(centerId, ['parent']) && userId in get(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid)).data.linkedStudentIds)
        );
        allow write: if false; 
      }

      match /dailyStudentStats/{date}/students/{studentId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId || 
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          (hasRole(centerId, ['parent']) && studentId in get(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid)).data.linkedStudentIds)
        );
      }

      match /studyLogs/{userId}/days/{date} {
        allow read: if isSignedIn() && (
          request.auth.uid == userId || 
          hasRole(centerId, ['centerAdmin', 'teacher']) ||
          (hasRole(centerId, ['parent']) && userId in get(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid)).data.linkedStudentIds)
        );
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      match /leaderboards/{period}/{metric}/entries/{entryId} {
        allow read: if isSignedIn();
      }

      match /config/growthTree {
        allow read: if isSignedIn();
        allow write: if hasRole(centerId, ['centerAdmin']);
      }

      match /attendanceRecords/{date}/students/{studentId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || hasRole(centerId, ['centerAdmin', 'teacher']));
        allow write: if hasRole(centerId, ['centerAdmin', 'teacher']);
      }

      match /plans/{studentId}/weeks/{week}/items/{itemId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || hasRole(centerId, ['centerAdmin', 'teacher']));
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /records/{recordId} {
        allow read: if isSignedIn() && hasRole(centerId, ['centerAdmin', 'teacher']);
      }
    }

    match /inviteCodes/{code} {
      allow get: if isSignedIn();
    }

    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    // Collection Group rules for Teacher Dashboard
    match /{path=**}/records/{recordId} {
      allow read: if isSignedIn() && hasRole(resource.data.centerId, ['centerAdmin', 'teacher']);
    }
  }
}