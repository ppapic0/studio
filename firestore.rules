
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getMembership(centerId) {
      return get(/databases/$(database)/documents/userCenters/$(request.auth.uid)/centers/$(centerId)).data;
    }

    function isMember(centerId) {
      return isSignedIn() && exists(/databases/$(database)/documents/userCenters/$(request.auth.uid)/centers/$(centerId));
    }

    function isStaff(centerId) {
      // getMembership 내부에서 이미 exists와 유사한 체크를 하므로 멤버십 데이터의 role을 직접 확인
      return isSignedIn() && getMembership(centerId).role in ['teacher', 'centerAdmin'];
    }

    // --- 유저 프로필 ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 유저별 센터 역인덱스 (재귀 방지를 위해 단순화) ---
    match /userCenters/{userId}/centers/{centerId} {
      // 본인은 항상 자신의 가입 정보를 읽을 수 있어야 함 (isStaff 체크 제거로 재귀 방지)
      allow read: if isSignedIn() && (request.auth.uid == userId || exists(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid)));
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 센터별 데이터 ---
    match /centers/{centerId} {
      allow get: if isMember(centerId);
      
      // 선생님/관리자는 해당 센터의 모든 하위 데이터를 읽고 쓸 수 있음
      match /{allSubcollections=**} {
        allow read, write: if isStaff(centerId);
      }

      match /members/{memberId} {
        allow read: if isMember(centerId) && (request.auth.uid == memberId || isStaff(centerId));
      }

      match /students/{studentId} {
        allow read: if isMember(centerId);
        allow write: if isSignedIn() && (request.auth.uid == studentId || isStaff(centerId));
      }

      // 학습 계획: 본인 것만 쓰기 가능, 읽기는 본인 및 스태프
      match /plans/{studentId}/weeks/{week}/items/{itemId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || isStaff(centerId));
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      // 학습 로그: 본인 것만 쓰기 가능, 읽기는 본인 및 스태프
      match /studyLogs/{studentId}/days/{date} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || isStaff(centerId));
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }

      match /growthProgress/{studentId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || isStaff(centerId));
        allow write: if isSignedIn() && (request.auth.uid == studentId || isStaff(centerId));
      }

      match /dailyStudentStats/{date}/students/{studentId} {
        allow read: if isMember(centerId) && (request.auth.uid == studentId || isStaff(centerId));
      }

      match /dailyReports/{reportId} {
        allow read: if isMember(centerId) && (resource.data.studentId == request.auth.uid || isStaff(centerId));
      }
      
      match /attendanceCurrent/{id} {
        allow read: if isMember(centerId);
      }
      
      // 상담 예약: 학생은 자신의 예약만 조회/생성/수정 가능
      match /counselingReservations/{id} {
        allow read: if isMember(centerId) && (isStaff(centerId) || (resource != null && resource.data.studentId == request.auth.uid) || (resource == null && request.resource.data.studentId == request.auth.uid));
        allow create: if isMember(centerId) && request.resource.data.studentId == request.auth.uid;
        allow update, delete: if isMember(centerId) && (isStaff(centerId) || (resource != null && resource.data.studentId == request.auth.uid));
      }
      
      // 상담 일지: 본인 또는 선생님만 조회 가능
      match /counselingLogs/{id} {
        allow read: if isMember(centerId) && (isStaff(centerId) || (resource != null && resource.data.studentId == request.auth.uid));
        allow write: if isStaff(centerId);
      }
    }

    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 시스템 예외 (동백 센터 관리자용)
    match /{document=**} {
      allow read, write: if isSignedIn() && isStaff('learning-lab-dongbaek');
    }
  }
}
