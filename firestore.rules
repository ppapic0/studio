
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- [상담 시스템] ---
    // 최우선 순위로 배치하여 다른 규칙과의 충돌을 방지합니다.
    // 사용자 요청에 따라 로그인만 되어 있으면 해당 센터의 상담 데이터를 자유롭게 읽고 쓸 수 있도록 허용합니다.
    match /centers/{centerId}/counselingReservations/{id} {
      allow read, write: if isSignedIn();
    }

    match /centers/{centerId}/counselingLogs/{id} {
      allow read, write: if isSignedIn();
    }

    // --- 유저 프로필 ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 유저별 센터 가입 정보 ---
    match /userCenters/{userId}/centers/{centerId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 센터별 데이터 관리 ---
    match /centers/{centerId} {
      allow read, write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // 초대 코드
    match /inviteCodes/{code} {
      allow read, write: if isSignedIn();
    }
  }
}
