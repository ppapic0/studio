rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    /**
     * Gets the user's role data from their membership document within a specific center.
     * This is the core of the role-based access control system.
     */
    function getUserMembership(centerId) {
      return get(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid));
    }
    /**
     * Checks if a user has an active membership document in a center.
     */
    function isCenterMember(centerId) {
      return isSignedIn() && exists(/databases/$(database)/documents/centers/$(centerId)/members/$(request.auth.uid));
    }
    function isCenterAdmin(centerId) {
      return isCenterMember(centerId) && getUserMembership(centerId).data.role == 'admin';
    }
    function isCenterTeacher(centerId) {
      return isCenterMember(centerId) && getUserMembership(centerId).data.role == 'teacher';
    }
    function isCenterStaff(centerId) {
      return isCenterAdmin(centerId) || isCenterTeacher(centerId);
    }
    /**
     * Placeholder function for parent access.
     * TODO: This requires a data model change to link parent users to student users.
     * For now, it always returns false, effectively disabling parent-specific access.
     */
    function isParentOfStudent(centerId, studentId) {
      // Example implementation might be:
      // return isCenterMember(centerId) && studentId in getUserMembership(centerId).data.childrenIds;
      return false;
    }
    /**
     * Grants access if the requesting user is the student themselves OR a staff member of the center.
     */
    function isSelfOrStaff(centerId, studentId) {
      return isOwner(studentId) || isCenterStaff(centerId);
    }
    /**
     * Grants read access if the user is the student, a staff member, or a linked parent.
     */
    function isSelfOrStaffOrParent(centerId, studentId) {
      return isSelfOrStaff(centerId, studentId) || isParentOfStudent(centerId, studentId);
    }
    /**
     * Validates that the 'id' field of a new user document matches the user's auth UID.
     */
    function incomingUserDataIsValid(userId) {
      return request.resource.data.id == userId;
    }
    
    function incomingStudentDataIsValid(centerId, studentId) {
      return request.resource.data.centerId == centerId &&
             (request.resource.data.studentId == studentId || request.resource.data.uid == studentId);
    }

    function coreIdsAreImmutable(studentId) {
      let isStudentIdImmutable = request.resource.data.studentId == resource.data.studentId || request.resource.data.uid == resource.data.uid;
      let isCenterIdImmutable = request.resource.data.centerId == resource.data.centerId;

      return isCenterIdImmutable &&
             (studentId == null || !isOwner(studentId) || isStudentIdImmutable);
    }

    /**
     * @description Manages user profile data.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && incomingUserDataIsValid(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      /**
       * @description Manages user-specific notification preferences for a center.
       * @path /users/{userId}/notificationPreferences/{centerId}
       */
      match /notificationPreferences/{centerId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }
    
    /**
     * @description Manages the reverse index of a user's center memberships for quick lookups.
     * @path /userCenters/{uid}/centers/{centerId}
     */
    match /userCenters/{uid}/centers/{centerId} {
      allow get, list: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    /**
     * @description Defines a study center and its top-level settings.
     * @path /centers/{centerId}
     */
    match /centers/{centerId} {
      allow get: if isCenterMember(centerId);
      allow list: if false;
      allow create: if false;
      allow update: if isCenterAdmin(centerId) && resource != null;
      allow delete: if false;

      /**
       * @description Manages user roles and membership within a center.
       * @path /centers/{centerId}/members/{userId}
       */
      match /members/{userId} {
        allow get: if isCenterMember(centerId);
        allow list: if isCenterMember(centerId);
        allow create: if isCenterAdmin(centerId);
        allow update: if (isCenterAdmin(centerId) || isOwner(userId)) && resource != null;
        allow delete: if (isCenterAdmin(centerId) || isOwner(userId)) && resource != null;
      }

      /**
       * @description Manages invite codes for onboarding new members.
       * @path /centers/{centerId}/inviteCodes/{inviteCodeId}
       */
      match /inviteCodes/{inviteCodeId} {
        allow get: if isSignedIn();
        allow list: if isCenterStaff(centerId);
        allow create: if isCenterStaff(centerId);
        allow update: if isCenterStaff(centerId) && resource != null;
        allow delete: if isCenterStaff(centerId) && resource != null;
      }
      
      /**
       * @description Student-specific study plans, keyed by user UID.
       * @path /centers/{centerId}/plans/{uid}
       */
      match /plans/{uid} {
        /**
         * @description Manages a student's weekly study plans.
         * @path /centers/{centerId}/plans/{uid}/weeks/{weekKey}
         */
        match /weeks/{weekKey} {
          allow get: if isSelfOrStaffOrParent(centerId, uid);
          allow list: if isSelfOrStaffOrParent(centerId, uid);
          allow create: if isSelfOrStaff(centerId, uid) && incomingStudentDataIsValid(centerId, uid);
          allow update: if isSelfOrStaff(centerId, uid) && resource != null && coreIdsAreImmutable(uid);
          allow delete: if isSelfOrStaff(centerId, uid) && resource != null;

          /**
           * @description Manages individual items within a weekly study plan.
           * @path /centers/{centerId}/plans/{uid}/weeks/{weekKey}/items/{itemId}
           */
          match /items/{itemId} {
            allow get: if isSelfOrStaffOrParent(centerId, uid);
            allow list: if isSelfOrStaffOrParent(centerId, uid);
            allow create: if isSelfOrStaff(centerId, uid);
            allow update: if isSelfOrStaff(centerId, uid) && resource != null;
            allow delete: if isSelfOrStaff(centerId, uid) && resource != null;
          }
        }
      }
      
      /**
       * @description Student-specific study logs, keyed by user UID.
       * @path /centers/{centerId}/studyLogs/{uid}
       */
      match /studyLogs/{uid} {
        /**
         * @description Manages a student's daily study time logs.
         * @path /centers/{centerId}/studyLogs/{uid}/days/{dateKey}
         */
        match /days/{dateKey} {
          allow get: if isSelfOrStaffOrParent(centerId, uid);
          allow list: if isSelfOrStaffOrParent(centerId, uid);
          allow create: if isSelfOrStaff(centerId, uid) && incomingStudentDataIsValid(centerId, uid);
          allow update: if isSelfOrStaff(centerId, uid) && resource != null && coreIdsAreImmutable(uid);
          allow delete: if isSelfOrStaff(centerId, uid) && resource != null;

          /**
           * @description Manages study time logs broken down by subject.
           * @path /centers/{centerId}/studyLogs/{uid}/days/{dateKey}/subjects/{studyLogSubjectId}
           */
          match /subjects/{studyLogSubjectId} {
            allow get: if isSelfOrStaffOrParent(centerId, uid);
            allow list: if isSelfOrStaffOrParent(centerId, uid);
            allow create: if isSelfOrStaff(centerId, uid);
            allow update: if isSelfOrStaff(centerId, uid) && resource != null;
            allow delete: if isSelfOrStaff(centerId, uid) && resource != null;
          }
        }
      }

      /**
       * @description Manages student attendance records, grouped by date.
       * @path /centers/{centerId}/attendanceRecords/{dateKey}/students/{studentId}
       */
      match /attendanceRecords/{dateKey}/students/{studentId} {
        allow get: if isSelfOrStaffOrParent(centerId, studentId);
        allow list: if isSelfOrStaffOrParent(centerId, studentId);
        allow create: if isSelfOrStaff(centerId, studentId) && incomingStudentDataIsValid(centerId, studentId);
        allow update: if isSelfOrStaff(centerId, studentId) && resource != null && coreIdsAreImmutable(studentId);
        allow delete: if isCenterStaff(centerId) && resource != null;
      }

      /**
       * @description Stores aggregated leaderboard data.
       * @path /centers/{centerId}/leaderboards/{periodKey}/{metricKey}/entries/{studentId}
       */
      match /leaderboards/{periodKey}/{metricKey}/entries/{studentId} {
        allow get: if isCenterMember(centerId);
        allow list: if isCenterMember(centerId);
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Stores aggregated daily performance statistics for students.
       * @path /centers/{centerId}/dailyStudentStats/{dateKey}/students/{studentId}
       */
      match /dailyStudentStats/{dateKey}/students/{studentId} {
        allow get: if isSelfOrStaffOrParent(centerId, studentId);
        allow list: if isSelfOrStaffOrParent(centerId, studentId);
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Stores AI-generated content like risk reports and summaries.
       * @path /centers/{centerId}/aiOutputs/{studentId}/records/{aiOutputId}
       */
      match /aiOutputs/{studentId}/records/{aiOutputId} {
        allow get: if isCenterStaff(centerId);
        allow list: if isCenterStaff(centerId);
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Records important system and user actions for auditing.
       * @path /centers/{centerId}/auditLogs/{auditLogId}
       */
      match /auditLogs/{auditLogId} {
        allow get: if isCenterAdmin(centerId);
        allow list: if isCenterAdmin(centerId);
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Stores aggregated monthly statistics for the entire center.
       * @path /centers/{centerId}/centerStats/{monthKey}
       */
      match /centerStats/{monthKey} {
        allow get: if isCenterStaff(centerId);
        allow list: if isCenterStaff(centerId);
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Manages the physical or virtual seats available in a center.
       * @path /centers/{centerId}/seats/{seatId}
       */
      match /seats/{seatId} {
        allow get: if isCenterMember(centerId);
        allow list: if isCenterMember(centerId);
        allow create: if isCenterAdmin(centerId);
        allow update: if isCenterAdmin(centerId) && resource != null;
        allow delete: if isCenterAdmin(centerId) && resource != null;
      }

      /**
       * @description Manages the assignment of students to seats for a given month.
       * @path /centers/{centerId}/seatAssignments/{monthKey}/students/{studentId}
       */
      match /seatAssignments/{monthKey}/students/{studentId} {
        allow get: if isSelfOrStaffOrParent(centerId, studentId);
        allow list: if isSelfOrStaffOrParent(centerId, studentId);
        allow create: if isCenterAdmin(centerId);
        allow update: if isCenterAdmin(centerId) && resource != null;
        allow delete: if isCenterAdmin(centerId) && resource != null;
      }

      /**
       * @description Manages student enrollment periods and status.
       * @path /centers/{centerId}/enrollments/{enrollmentId}
       */
      match /enrollments/{enrollmentId} {
        allow get: if isCenterStaff(centerId) || (resource != null && isOwner(resource.data.studentId));
        allow list: if isCenterStaff(centerId);
        allow create: if isCenterAdmin(centerId);
        allow update: if isCenterAdmin(centerId) && resource != null;
        allow delete: if isCenterAdmin(centerId) && resource != null;
      }
    }
  }
}
