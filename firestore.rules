
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 공통 헬퍼 함수 ---
    function isSignedIn() {
      return request.auth != null;
    }

    // 사용자의 역할(Role)을 직접 가져오는 함수 (가장 단순한 경로 사용)
    function getRole(centerId) {
      return get(/databases/$(database)/documents/userCenters/$(request.auth.uid)/centers/$(centerId)).data.role;
    }

    // 멤버 여부 확인
    function isMember(centerId) {
      return isSignedIn() && exists(/databases/$(database)/documents/userCenters/$(request.auth.uid)/centers/$(centerId));
    }

    // 선생님/관리자 여부 확인
    function isStaff(centerId) {
      return isMember(centerId) && getRole(centerId) in ['teacher', 'centerAdmin'];
    }

    // --- 유저 프로필 ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 유저별 센터 가입 정보 ---
    match /userCenters/{userId}/centers/{centerId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff(centerId));
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- 센터별 데이터 관리 ---
    match /centers/{centerId} {
      // 센터 기본 정보 조회
      allow get: if isMember(centerId);
      
      // [상담 예약]
      match /counselingReservations/{id} {
        // 학생은 본인 데이터만, 선생님은 전체 조회 가능
        allow read: if isMember(centerId) && (isStaff(centerId) || resource.data.studentId == request.auth.uid);
        // 생성은 센터 멤버만 가능하며, 본인 ID를 담아야 함
        allow create: if isMember(centerId) && request.resource.data.studentId == request.auth.uid;
        // 수정/삭제는 본인 또는 선생님만 가능
        allow update, delete: if isMember(centerId) && (isStaff(centerId) || resource.data.studentId == request.auth.uid);
      }
      
      // [상담 일지]
      match /counselingLogs/{id} {
        // 읽기: 본인 기록만(학생) 또는 전체(선생님)
        allow read: if isMember(centerId) && (isStaff(centerId) || resource.data.studentId == request.auth.uid);
        // 쓰기: 선생님만 가능
        allow write: if isStaff(centerId);
      }

      // [기타 하위 컬렉션 공통 규칙]
      match /members/{memberId} {
        allow read: if isMember(centerId);
      }
      match /students/{studentId} {
        allow read: if isMember(centerId);
        allow write: if isStaff(centerId) || (isSignedIn() && request.auth.uid == studentId);
      }
      match /plans/{studentId}/weeks/{week}/items/{itemId} {
        allow read: if isStaff(centerId) || (isSignedIn() && request.auth.uid == studentId);
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }
      match /studyLogs/{studentId}/days/{date} {
        allow read: if isStaff(centerId) || (isSignedIn() && request.auth.uid == studentId);
        allow write: if isSignedIn() && request.auth.uid == studentId;
      }
      match /dailyStudentStats/{date}/students/{studentId} {
        allow read: if isStaff(centerId) || (isSignedIn() && request.auth.uid == studentId);
      }
      match /dailyReports/{reportId} {
        allow read: if isStaff(centerId) || (isSignedIn() && resource.data.studentId == request.auth.uid);
      }
      match /attendanceCurrent/{id} {
        allow read: if isMember(centerId);
        allow write: if isStaff(centerId);
      }
      match /growthProgress/{studentId} {
        allow read: if isMember(centerId);
        allow write: if isStaff(centerId) || (isSignedIn() && request.auth.uid == studentId);
      }
    }

    // 초대 코드 (임시 허용)
    match /inviteCodes/{code} {
      allow read, write: if isSignedIn();
    }
  }
}
